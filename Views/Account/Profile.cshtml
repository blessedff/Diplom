@model StationeryShop.Models.Customer

@{
    ViewData["Title"] = "Личный кабинет";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .profile-container {
        animation: fadeInUp 0.4s ease-out;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    .profile-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
        overflow: hidden;
        height: 100%;
    }

        .profile-card .card-header {
            background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
            color: white;
            padding: 15px 20px;
            border: none;
        }

            .profile-card .card-header h5 {
                margin: 0;
                font-weight: 600;
            }

        .profile-card .card-body {
            padding: 25px;
        }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 12px 15px;
        transition: all 0.2s ease;
        width: 100%;
    }

        .form-control:focus {
            border-color: #2c5aa0;
            box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
            outline: none;
        }

    .btn-save {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 30px;
        padding: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        width: 100%;
        color: white;
        cursor: pointer;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
            color: white;
        }

    .btn-all-orders {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-all-orders:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.4);
            color: white;
            background: linear-gradient(135deg, #3a7bd5, #00d2ff);
        }

    .stat-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

        .stat-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .orders-table {
        width: 100%;
        border-collapse: collapse;
    }

        .orders-table th {
            background: #f8f9fa;
            font-weight: 600;
            padding: 12px 10px;
            border-bottom: 1px solid #e9ecef;
            font-size: 0.8rem;
            color: #4a5568;
        }

        .orders-table td {
            padding: 10px 10px;
            border-bottom: 1px solid #f0f2f5;
            vertical-align: middle;
            font-size: 0.85rem;
        }

        .orders-table tr:last-child td {
            border-bottom: none;
        }

    .order-number {
        font-weight: 700;
        color: #2c5aa0;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .status-completed {
        background: #d4edda;
        color: #155724;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #721c24;
    }

    .status-ready {
        background: #fff3cd;
        color: #856404;
    }

    .status-default {
        background: #cfe2ff;
        color: #084298;
    }

    .btn-action {
        background: none;
        border: none;
        padding: 5px 10px;
        border-radius: 30px;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: 0.7rem;
    }

    .btn-action-info {
        background: #e8f4fd;
        color: #2c5aa0;
    }

        .btn-action-info:hover {
            background: #2c5aa0;
            color: white;
        }

    .btn-action-primary {
        background: linear-gradient(135deg, #e8f4fd, #d4eaf7);
        color: #2c5aa0;
    }

        .btn-action-primary:hover {
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            color: white;
        }

    .empty-orders {
        text-align: center;
        padding: 40px 20px;
    }

        .empty-orders i {
            font-size: 3rem;
            color: #cbd5e1;
            margin-bottom: 15px;
        }

    .password-required {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        margin-top: 20px;
        border-left: 4px solid #ffc107;
    }

    .required-field::after {
        content: '*';
        color: #dc3545;
        margin-left: 4px;
    }

    @@media (max-width: 768px) {
        .orders-table th,
        .orders-table td {
            padding: 8px 5px;
            font-size: 0.7rem;
        }

        .btn-action {
            padding: 3px 6px;
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="profile-container">
    <h2 class="page-title">
        <i class="bi bi-person-circle me-2"></i> Личный кабинет
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- ЛЕВАЯ КОЛОНКА: Редактирование профиля -->
        <div class="col-lg-7">
            <div class="profile-card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Редактирование профиля</h5>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateProfile" method="post" id="profileForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label required-field">ФИО</label>
                            <input asp-for="FullName" class="form-control" placeholder="Введите ваше ФИО" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label required-field">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label">Телефон</label>
                                <input asp-for="Phone" class="form-control" placeholder="+375 XX XXX-XX-XX" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Address" class="form-label">Адрес</label>
                                <input asp-for="Address" class="form-control" placeholder="Город, улица, дом" />
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>
                        </div>

                        @if (!isAdmin)
                        {
                            <div class="password-required">
                                <label class="form-label required-field">Подтверждение пароля</label>
                                <input type="password" name="currentPassword" class="form-control" placeholder="Введите текущий пароль для сохранения изменений" required />
                                <small class="text-muted"><i class="bi bi-shield-lock me-1"></i> Для сохранения изменений необходимо ввести текущий пароль</small>
                            </div>
                        }

                        <button type="submit" class="btn btn-save mt-3">
                            <i class="bi bi-save me-2"></i> Сохранить изменения
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- ПРАВАЯ КОЛОНКА: Статистика -->
        <div class="col-lg-5">
            @if (!isAdmin)
            {
                <div class="profile-card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-graph-up me-2"></i> Моя статистика</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="stat-box">
                                    <div class="stat-number text-primary">@Model.Orders.Count</div>
                                    <div class="stat-label">Всего заказов</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="stat-box">
                                    <div class="stat-number text-success">
                                        @Model.Orders.Where(o => o.Status == "Выполнен").Count()
                                    </div>
                                    <div class="stat-label">Выполнено</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Последние заказы (на всю ширину) -->
    @if (!isAdmin)
    {
        <div class="profile-card mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i> Последние заказы</h5>
                <a asp-controller="Orders" asp-action="Index" class="btn-all-orders">
                    <i class="bi bi-list-ul me-1"></i> Все заказы <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body">
                @if (Model.Orders.Any())
                {
                    <div class="table-responsive">
                        <table class="orders-table">
                            <thead>
                                <tr>
                                    <th>№ заказа</th>
                                    <th>Дата</th>
                                    <th>Сумма</th>
                                    <th>Статус</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate).Take(5))
                                {
                                    <tr>
                                        <td class="order-number">#@order.OrderID</td>
                                        <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                        <td class="fw-bold">@order.TotalAmount.ToString("0.00") BYN</td>
                                        <td>
                                            <span class="status-badge
                                                            @(order.Status == "Выполнен" ? "status-completed" :
                                                                                                    order.Status == "Отменен" ? "status-cancelled" :
                                                                                                    order.Status == "Готов к выдаче" ? "status-ready" : "status-default")">
                                    @if (order.Status == "Выполнен")
                                                {
                                                    <i class="bi bi-check-circle"></i>
                                                }
                                                else if (order.Status == "Отменен")
                                                {
                                                    <i class="bi bi-x-circle"></i>
                                                }
                                                else if (order.Status == "Готов к выдаче")
                                                {
                                                    <i class="bi bi-clock-history"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-hourglass-split"></i>
                                                }
                                                @order.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="d-flex gap-1">
                                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderID"
                                                   class="btn-action btn-action-info" title="Детали">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-controller="Orders" asp-action="ClientReceipt" asp-route-id="@order.OrderID"
                                                   class="btn-action btn-action-primary" target="_blank" title="Чек">
                                                    <i class="bi bi-receipt"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    if (Model.Orders.Count() > 5)
                    {
                        <div class="text-center mt-2">
                            <small class="text-muted">Показаны последние 5 заказов из @Model.Orders.Count()</small>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-orders">
                        <i class="bi bi-inbox"></i>
                        <p class="text-muted mb-3">У вас пока нет заказов</p>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-primary rounded-pill">
                            <i class="bi bi-bag me-2"></i> Сделать первый заказ
                        </a>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Для администратора -->
    @if (isAdmin)
    {
        <div class="profile-card mt-4">
            <div class="card-body text-center text-muted">
                <i class="bi bi-shield-lock fs-1"></i>
                <p class="mt-2 mb-0">Вы вошли как администратор.</p>
                <p class="small">История заказов доступна в админ-панели.</p>
                <a asp-controller="Admin" asp-action="Orders" class="btn btn-outline-primary rounded-pill mt-2">
                    <i class="bi bi-speedometer2 me-2"></i> Перейти в админ-панель
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}