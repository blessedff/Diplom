@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Управление категориями";
}

<style>
    .category-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        border-radius: 16px;
        overflow: hidden;
        cursor: pointer;
    }

        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

    .filter-section {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .floating-add-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
        font-size: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(40, 167, 69, 0.4);
        transition: all 0.3s ease;
        z-index: 1000;
        text-decoration: none;
    }

        .floating-add-btn:hover {
            transform: scale(1.1);
            color: white;
        }

    .view-toggle {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .table-categories th {
        background: #f8f9fa;
        font-weight: 600;
    }
</style>



<div class="filter-section">
    <div class="row g-3 align-items-end">
        <div class="col-md-8">
            <label class="form-label fw-bold">🔍 Поиск категорий</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Название категории...">
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">📊 Сортировать по</label>
            <select id="sortBy" class="form-select">
                <option value="Name">Названию (А-Я)</option>
                <option value="NameDesc">Названию (Я-А)</option>
                <option value="Products">Количеству товаров (возр.)</option>
                <option value="ProductsDesc">Количеству товаров (убыв.)</option>
            </select>
        </div>
    </div>
</div>

<div id="cardsContainer" class="row g-4">
    <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Загрузка категорий...</p>
    </div>
</div>

<div id="tableViewContainer" style="display: none;">
    <div class="table-responsive">
        <table class="table table-hover table-categories">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Описание</th>
                    <th>Товаров</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>
</div>

<a asp-controller="Categories" asp-action="Create" class="floating-add-btn" title="Добавить категорию">
    <i class="bi bi-plus-lg"></i>
</a>

<div class="modal fade" id="categoryModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Информация о категории</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="categoryModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentCategories = [];
        let currentView = 'cards';

        async function loadCategories() {
            const search = $('#searchInput').val();
            const sortBy = $('#sortBy').val();

            let sortField = sortBy;
            let ascending = true;

            if (sortBy === 'NameDesc' || sortBy === 'ProductsDesc') {
                ascending = false;
            }

            $('#cardsContainer').html(`
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Загрузка категорий...</p>
                </div>
            `);

            try {
                const response = await fetch(`/Admin/GetCategories?search=${encodeURIComponent(search)}&sortBy=${sortField}&ascending=${ascending}`);
                const categories = await response.json();
                currentCategories = categories;
                renderCards(categories);
                renderTable(categories);
            } catch (error) {
                console.error('Ошибка загрузки:', error);
                $('#cardsContainer').html('<div class="col-12 text-center py-5 text-danger">Ошибка загрузки категорий</div>');
            }
        }

        function renderCards(categories) {
            if (!categories.length) {
                $('#cardsContainer').html(`
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                        <p class="mt-3 text-muted">Категории не найдены</p>
                        <a href="/Categories/Create" class="btn btn-primary mt-2">
                            <i class="bi bi-plus-circle"></i> Создать первую категорию
                        </a>
                    </div>
                `);
                return;
            }

            let html = '';
            for (const category of categories) {
                let badgeClass = 'bg-secondary';
                if (category.productsCount > 20) badgeClass = 'bg-success';
                else if (category.productsCount > 0) badgeClass = 'bg-info';

                html += `
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="card category-card h-100">
                            <div class="card-body text-center">
                                <div class="mb-3">
                                    <i class="bi bi-tags display-1 text-primary"></i>
                                </div>
                                <h5 class="card-title">${escapeHtml(category.name)}</h5>
                                <p class="card-text text-muted small">
                                    ${escapeHtml(category.description?.substring(0, 80) || 'Нет описания')}${category.description?.length > 80 ? '...' : ''}
                                </p>
                                <div class="mb-3">
                                    <span class="badge ${badgeClass}">${category.productsCount} товаров</span>
                                </div>
                                <div class="btn-group w-100">
                                    <button class="btn btn-outline-info btn-sm view-details" data-id="${category.categoryID}" title="Детали">
                                        <i class="bi bi-eye"></i> Детали
                                    </button>
                                    <a href="/Categories/Edit/${category.categoryID}" class="btn btn-outline-warning btn-sm" title="Редактировать">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="/Categories/Delete/${category.categoryID}" class="btn btn-outline-danger btn-sm" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }
            $('#cardsContainer').html(html);

            $('.view-details').on('click', function() {
                const categoryId = $(this).data('id');
                loadCategoryModal(categoryId);
            });
        }

        function renderTable(categories) {
            if (!categories.length) {
                $('#tableBody').html('<tr><td colspan="5" class="text-center text-muted">Категории не найдены</td><tr');
                return;
            }

            let html = '';
            for (const category of categories) {
                html += `
                    <tr>
                        <td>${category.categoryID}</td>
                        <td class="fw-bold">${escapeHtml(category.name)}</td>
                        <td>${escapeHtml(category.description?.substring(0, 60) || '—')}${category.description?.length > 60 ? '...' : ''}</td>
                        <td><span class="badge bg-secondary">${category.productsCount}</span></td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-info view-details" data-id="${category.categoryID}" title="Детали">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <a href="/Categories/Edit/${category.categoryID}" class="btn btn-outline-warning" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Categories/Delete/${category.categoryID}" class="btn btn-outline-danger" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                `;
            }
            $('#tableBody').html(html);

            $('.view-details').on('click', function() {
                const categoryId = $(this).data('id');
                loadCategoryModal(categoryId);
            });
        }

        function loadCategoryModal(categoryId) {
            const modalBody = $('#categoryModalBody');
            modalBody.html(`
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">Загрузка информации...</p>
                </div>
            `);

            fetch(`/Categories/DetailsModal/${categoryId}`)
                .then(response => response.text())
                .then(html => {
                    modalBody.html(html);
                    $('#categoryModal').modal('show');
                })
                .catch(error => {
                    modalBody.html(`
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i> Ошибка при загрузке информации
                        </div>
                    `);
                });
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        function setView(view) {
            currentView = view;
            if (view === 'cards') {
                $('#cardsContainer').show();
                $('#tableViewContainer').hide();
                $('#cardViewBtn').removeClass('btn-outline-primary').addClass('btn-primary');
                $('#tableViewBtn').removeClass('btn-primary').addClass('btn-outline-secondary');
            } else {
                $('#cardsContainer').hide();
                $('#tableViewContainer').show();
                $('#tableViewBtn').removeClass('btn-outline-secondary').addClass('btn-primary');
                $('#cardViewBtn').removeClass('btn-primary').addClass('btn-outline-primary');
            }
        }

        $('#searchInput').on('input', debounce(loadCategories, 500));
        $('#sortBy').on('change', loadCategories);
        $('#cardViewBtn').on('click', () => setView('cards'));
        $('#tableViewBtn').on('click', () => setView('table'));

        function debounce(func, wait) {
            let timeout;
            return function() {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, arguments), wait);
            };
        }

        $(document).ready(function() {
            loadCategories();
            setView('cards');
        });
    </script>
}