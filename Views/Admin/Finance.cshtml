<!-- Модальное окно добавления разового расхода -->
<div class="modal fade" id="addExpenseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Добавить разовый расход</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddExpense" method="post">
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label small fw-bold">Категория</label><select name="Category" class="form-select" required><option value="">-- Выберите --</option><option value="Ремонт">🔧 Ремонт</option><option value="Канцтовары">📝 Канцтовары</option><option value="Упаковка">📦 Упаковка</option><option value="Реклама">📢 Реклама</option><option value="Прочее">❓ Прочее</option></select></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Описание</label><input type="text" name="Description" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Сумма (BYN)</label><input type="number" name="Amount" class="form-control" step="0.01" min="0.01" required /></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Дата</label><input type="date" name="ExpenseDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required /></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Способ оплаты</label><select name="PaymentMethod" class="form-select"><option value="Наличные">💵 Наличные</option><option value="Карта">💳 Карта</option><option value="Безналичный">🏦 Безналичный</option></select></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Заметки</label><textarea name="Notes" class="form-control" rows="2"></textarea></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">➕ Добавить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Фильтр по дате
        document.getElementById('applyFilter').addEventListener('click', function() {
            var startDate = document.getElementById('startDate').value;
            var endDate = document.getElementById('endDate').value;
            window.location.href = '/Admin/Finance?startDate=' + startDate + '&endDate=' + endDate;
        });

        // Сворачивание списка заказов
        document.getElementById('ordersHeader').addEventListener('click', function() {
            var content = document.getElementById('ordersContent');
            var icon = document.getElementById('ordersIcon');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-up');
            } else {
                content.style.display = 'none';
                icon.classList.remove('bi-chevron-up');
                icon.classList.add('bi-chevron-down');
            }
        });

        // Сворачивание списка разовых расходов
        document.getElementById('expensesHeader').addEventListener('click', function(e) {
            if (e.target.closest('.btn')) return;
            var content = document.getElementById('expensesContent');
            var icon = document.getElementById('expensesIcon');
            if (content.style.display === 'none') {
                content.style.display = 'block';
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-up');
            } else {
                content.style.display = 'none';
                icon.classList.remove('bi-chevron-up');
                icon.classList.add('bi-chevron-down');
            }
        });

        // Модальное окно редактирования расходов
        document.getElementById('editExpensesBtn').addEventListener('click', function() {
            var modal = new bootstrap.Modal(document.getElementById('expensesModal'));
            modal.show();
        });

        // Отправка формы редактирования расходов
        document.getElementById('expensesForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var formData = new FormData(this);
            var data = {};
            formData.forEach((value, key) => data[key] = value);
            
            fetch('/Admin/UpdateExpensesSettings', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => response.json())
            .then(result => {
                if (result.success) {
                    location.reload();
                } else {
                    alert('Ошибка: ' + result.message);
                }
            });
        });
    </script>
}