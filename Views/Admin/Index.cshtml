@{
    ViewData["Title"] = "Панель администратора";
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Панель администратора</h2>

<!-- Статистика -->
<div class="row mb-4">
    <div class="col-md-2 col-6">
        <div class="card text-center bg-primary text-white">
            <div class="card-body">
                <h4 class="card-title">@ViewBag.TotalProducts</h4>
                <p class="card-text">Товаров</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="card text-center bg-success text-white">
            <div class="card-body">
                <h4 class="card-title">@ViewBag.TotalCategories</h4>
                <p class="card-text">Категорий</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="card text-center bg-info text-white">
            <div class="card-body">
                <h4 class="card-title">@ViewBag.TotalCustomers</h4>
                <p class="card-text">Клиентов</p>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-6">
        <div class="card text-center bg-warning text-white">
            <div class="card-body">
                <h4 class="card-title">@ViewBag.TotalOrders</h4>
                <p class="card-text">Заказов</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-12">
        <div class="card text-center bg-danger text-white">
            <div class="card-body">
                <h4 class="card-title">@ViewBag.TotalRevenue.ToString("0.00") byn</h4>
                <p class="card-text">Общая выручка</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Последние заказы -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Последние заказы</h5>
                <a asp-action="Orders" class="btn btn-sm btn-outline-primary">Все заказы</a>
            </div>
            <div class="card-body">
                @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Клиент</th>
                                    <th>Дата</th>
                                    <th>Сумма</th>
                                    <th>Статус</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in ViewBag.RecentOrders)
                                {
                                    <tr>
                                        <td>#@order.OrderID</td>
                                        <td>@order.Customer?.FullName</td>
                                        <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                        <td>@order.TotalAmount.ToString("0.00") byn</td>
                                        <td>
                                            <span class="badge 
                                                @(order.Status == "Выполнен" ? "bg-success" :
                                                  order.Status == "Отменен" ? "bg-danger" :
                                                  order.Status == "Готов к выдаче" ? "bg-warning" : "bg-info")">
                                                @order.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">Заказов пока нет</p>
                }
            </div>
        </div>
    </div>

    <!-- Товары с низким запасом -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Низкий запас</h5>
                <a asp-action="Products" class="btn btn-sm btn-outline-primary">Все товары</a>
            </div>
            <div class="card-body">
                @if (ViewBag.LowStockProducts != null && ViewBag.LowStockProducts.Count > 0)
                {
                    <div class="list-group">
                        @foreach (var product in ViewBag.LowStockProducts)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-bold">@product.Name</div>
                                    <small class="text-muted">Осталось: @product.StockQuantity</small>
                                </div>
                                <span class="badge bg-danger rounded-pill">@product.StockQuantity</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">Все товары в достаточном количестве</p>
                }
            </div>
        </div>

        <!-- Быстрые действия -->
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="card-title mb-0">Быстрые действия</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Products" asp-action="Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Добавить товар
                    </a>
                    <a asp-controller="Categories" asp-action="Create" class="btn btn-info">
                        <i class="bi bi-tags"></i> Добавить категорию
                    </a>
                    <a asp-action="Orders" class="btn btn-warning">
                        <i class="bi bi-bag"></i> Управление заказами
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>