@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Панель администратора";
}

<style>
    .stat-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
        cursor: pointer;
        overflow: hidden;
        position: relative;
    }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #3a7bd5, #00d2ff);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .stat-icon {
        font-size: 2.5rem;
        opacity: 0.3;
        position: absolute;
        bottom: 15px;
        right: 15px;
    }

    .order-status {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }
</style>

<!-- Карточки статистики -->
<div class="row mb-4">
    <div class="col-md-3 col-6 mb-3">
        <div class="card stat-card bg-primary text-white">
            <div class="card-body">
                <h6 class="card-title">Товары</h6>
                <h2 class="mb-0">@ViewBag.TotalProducts</h2>
                <small>в каталоге</small>
                <i class="bi bi-box-seam stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="card stat-card bg-success text-white">
            <div class="card-body">
                <h6 class="card-title">Категории</h6>
                <h2 class="mb-0">@ViewBag.TotalCategories</h2>
                <small>в каталоге</small>
                <i class="bi bi-tags stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="card stat-card bg-info text-white">
            <div class="card-body">
                <h6 class="card-title">Клиенты</h6>
                <h2 class="mb-0">@ViewBag.TotalCustomers</h2>
                <small>зарегистрировано</small>
                <i class="bi bi-people stat-icon"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6 mb-3">
        <div class="card stat-card bg-warning text-white">
            <div class="card-body">
                <h6 class="card-title">Заказы</h6>
                <h2 class="mb-0">@ViewBag.TotalOrders</h2>
                <small>всего</small>
                <i class="bi bi-bag-check stat-icon"></i>
            </div>
        </div>
    </div>
</div>

<!-- Дополнительная статистика -->
<div class="row mb-4">
    <div class="col-md-6 mb-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <h6 class="text-muted mb-3">📊 Общая выручка</h6>
                <h2 class="text-success mb-0">@ViewBag.TotalRevenue.ToString("0.00") BYN</h2>
                <small>за всё время</small>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-3">
        <div class="card stat-card border-0">
            <div class="card-body">
                <h6 class="text-muted mb-3">📈 Средний чек</h6>
                <h2 class="text-primary mb-0">
                    @((ViewBag.TotalOrders > 0 ? ViewBag.TotalRevenue / ViewBag.TotalOrders : 0).ToString("0.00")) BYN
                </h2>
                <small>на один заказ</small>
            </div>
        </div>
    </div>
</div>

<!-- Последние заказы -->
<div class="card mb-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Последние заказы</h5>
        <a asp-action="Orders" class="btn btn-sm btn-outline-primary">Все заказы →</a>
    </div>
    <div class="card-body">
        @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>№ заказа</th>
                            <th>Клиент</th>
                            <th>Дата</th>
                            <th>Сумма</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in ViewBag.RecentOrders)
                        {
                            <tr>
                                <td>#@order.OrderID</td>
                                <td>@order.Customer?.FullName</td>
                                <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                                <td>@order.TotalAmount.ToString("0.00") BYN</td>
                                <td>
                                    @if (order.Status == "Выполнен")
                                    {
                                        <span class="order-status" style="background: #28a745;"></span>
                                        <span class="text-success">@order.Status</span>
                                    }
                                    else if (order.Status == "Отменен")
                                    {
                                        <span class="order-status" style="background: #dc3545;"></span>
                                        <span class="text-danger">@order.Status</span>
                                    }
                                    else if (order.Status == "Готов к выдаче")
                                    {
                                        <span class="order-status" style="background: #ffc107;"></span>
                                        <span class="text-warning">@order.Status</span>
                                    }
                                    else
                                    {
                                        <span class="order-status" style="background: #17a2b8;"></span>
                                        <span class="text-info">@order.Status</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderID"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center mb-0">Заказов пока нет</p>
        }
    </div>
</div>

<!-- Товары с низким запасом и быстрые действия -->
<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle text-warning"></i> Товары с низким запасом</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.LowStockProducts != null && ViewBag.LowStockProducts.Count > 0)
                {
                    <div class="list-group">
                        @foreach (var product in ViewBag.LowStockProducts)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@product.Name</strong>
                                    <br>
                                    <small class="text-muted">Осталось: @product.StockQuantity шт.</small>
                                </div>
                                <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.ProductID"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Пополнить
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted text-center mb-0">✅ Все товары в достаточном количестве</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-lightning-charge text-primary"></i> Быстрые действия</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Products" asp-action="Create" class="btn btn-outline-success">
                        <i class="bi bi-plus-circle"></i> Добавить товар
                    </a>
                    <a asp-controller="Categories" asp-action="Create" class="btn btn-outline-info">
                        <i class="bi bi-tag"></i> Добавить категорию
                    </a>
                    <a asp-action="Orders" class="btn btn-outline-warning">
                        <i class="bi bi-bag-check"></i> Управление заказами
                    </a>
                    <a asp-action="Analytics" class="btn btn-outline-primary">
                        <i class="bi bi-graph-up"></i> Перейти к аналитике
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>