@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Панель администратора";
}

<style>
    /* Анимации и общие стили */
    .dashboard-container {
        animation: fadeInUp 0.4s ease-out;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0;
    }

    .page-subtitle {
        color: #6c757d;
        font-size: 0.85rem;
    }

    .date-time {
        text-align: right;
    }

    .date-time .date {
        font-size: 0.85rem;
        font-weight: 500;
        color: #2c5aa0;
    }

    .date-time .time {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    /* Карточки статистики (как на других вкладках) */
    .stat-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        height: 100%;
    }


    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .stat-icon {
        font-size: 2.5rem;
        opacity: 0.3;
        position: absolute;
        bottom: 15px;
        right: 15px;
    }
    /* Секция последних заказов */
    .recent-section {
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        overflow: hidden;
        margin-top: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
    }

    .section-header {
        padding: 18px 24px;
        background: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            font-size: 1.2rem;
            color: #2c5aa0;
        }

        .section-title h5 {
            margin: 0;
            font-weight: 600;
            font-size: 1rem;
            color: #1a1a2e;
        }

    
    .btn-all-orders {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        border-radius: 40px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }

        .btn-all-orders:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
            color: white;
            background: linear-gradient(135deg, #3a7bd5, #00d2ff);
        }

        .btn-all-orders i {
            font-size: 0.9rem;
        }


    /* Анимация */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .date-time {
            text-align: left;
            margin-top: 10px;
        }

        .orders-table th,
        .orders-table td {
            padding: 8px 10px;
            font-size: 0.7rem;
        }
    }
</style>


    <div class="row mb-4">
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-primary text-white" onclick="location.href='/Admin/Products'">
                <div class="card-body">
                    <h6 class="card-title">Товары</h6>
                    <h2 class="mb-0">@ViewBag.TotalProducts</h2>
                    <small>в каталоге</small>
                    <i class="bi bi-box-seam stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-success text-white" onclick="location.href='/Admin/Categories'">
                <div class="card-body">
                    <h6 class="card-title">Категории</h6>
                    <h2 class="mb-0">@ViewBag.TotalCategories</h2>
                    <small>в каталоге</small>
                    <i class="bi bi-tags stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-info text-white" onclick="location.href='/Admin/Customers'">
                <div class="card-body">
                    <h6 class="card-title">Клиенты</h6>
                    <h2 class="mb-0">@ViewBag.TotalCustomers</h2>
                    <small>зарегистрировано</small>
                    <i class="bi bi-people stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-warning text-white" onclick="location.href='/Admin/ProductQuestions'">
                <div class="card-body">
                    <h6 class="card-title">Новые вопросы</h6>
                    <h2 class="mb-0">@ViewBag.NewQuestionsToday</h2>
                    <small>ожидают ответа</small>
                    <i class="bi bi-question-circle stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-warning text-white" onclick="location.href='/Admin/Reviews?status=pending'">
                <div class="card-body">
                    <h6 class="card-title">Новые отзывы</h6>
                    <h2 class="mb-0">@ViewBag.NewReviewsToday</h2>
                    <small>на модерации</small>
                    <i class="bi bi-star stat-icon"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-6 mb-3">
            <div class="card stat-card bg-warning text-white" onclick="location.href='/Admin/Orders'">
                <div class="card-body">
                    <h6 class="card-title">Новые заказы</h6>
                    <h2 class="mb-0">@ViewBag.NewOrdersToday</h2>
                    <small>сегодня</small>
                    <i class="bi bi-bag-check stat-icon"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- ПОСЛЕДНИЕ ЗАКАЗЫ -->
<div class="recent-section">
    <div class="section-header">
        <div class="section-title">
            <i class="bi bi-clock-history me-2"></i>
            <h5>Последние заказы</h5>
        </div>
        <a href="/Admin/Orders" class="btn-all-orders">
            <i class="bi bi-list-ul me-1"></i> Все заказы
            <i class="bi bi-arrow-right ms-1"></i>
        </a>
    </div>
    <div class="table-responsive">
        @if (ViewBag.RecentOrders != null && ViewBag.RecentOrders.Count > 0)
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>№ заказа</th>
                        <th>Клиент</th>
                        <th>Дата</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in ViewBag.RecentOrders)
                    {
                        <tr onclick="location.href='/Admin/Orders'">
                            <td class="order-number">#@order.OrderID</td>
                            <td>@(order.Customer?.FullName ?? "Не указан")</td>
                            <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                            <td class="fw-bold text-success">@order.TotalAmount.ToString("0.00") BYN</td>
                            <td>
                                @{
                                    string statusClass = "status-default";
                                    string statusIcon = "bi-hourglass-split";
                                    if (order.Status == "Выполнен")
                                    {
                                        statusClass = "status-completed";
                                        statusIcon = "bi-check-circle";
                                    }
                                    else if (order.Status == "Отменен")
                                    {
                                        statusClass = "status-cancelled";
                                        statusIcon = "bi-x-circle";
                                    }
                                    else if (order.Status == "Готов к выдаче")
                                    {
                                        statusClass = "status-ready";
                                        statusIcon = "bi-clock-history";
                                    }
                                }
                                <span class="status-badge @statusClass">
                                    <i class="bi @statusIcon"></i> @order.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <p>Нет заказов</p>
            </div>
        }
    </div>
</div>
</div>
</div>

@section Scripts {
    <script>
    </script>
}