@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Логи входов";
}

<style>
    /* Дополнительные стили специфичные для логов */
    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0;
    }

    /* Карточки статистики */
    .stats-row {
        margin-bottom: 25px;
    }

    .stat-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
        height: 100%;
    }


        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .stat-icon {
        font-size: 2rem;
        opacity: 0.15;
        position: absolute;
        bottom: 12px;
        right: 15px;
    }

    /* Фильтры */
    .filter-bar {
        background: white;
        border-radius: 20px;
        padding: 20px 24px;
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 15px;
        border: 1px solid #eef2f6;
    }

    .filter-item {
        flex: 1;
        min-width: 150px;
    }

        .filter-item label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            display: block;
        }

        .filter-item input,
        .filter-item select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            font-size: 0.85rem;
        }

            .filter-item input:focus,
            .filter-item select:focus {
                border-color: #2c5aa0;
                box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
                outline: none;
            }

    /* Кнопки действий */
    .action-buttons-bar {
        display: flex;
        gap: 12px;
        margin-bottom: 25px;
        justify-content: flex-end;
    }

    .btn-clear {
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border: none;
        border-radius: 40px;
        padding: 10px 24px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        color: white;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-clear:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(239, 68, 68, 0.3);
        }

    .btn-export {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        border-radius: 40px;
        padding: 10px 24px;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        color: white;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-export:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
        }

    /* IP-адрес в таблице */
    .ip-address {
        font-family: 'Monaco', 'Menlo', monospace;
        font-size: 0.8rem;
        background: #f1f5f9;
        padding: 4px 8px;
        border-radius: 8px;
        display: inline-block;
    }

    /* User Agent */
    .user-agent {
        max-width: 250px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 0.75rem;
        color: #64748b;
    }

    /* Бейджи статусов */
    .status-success {
        background: #d1fae5;
        color: #065f46;
    }

    .status-failed {
        background: #fee2e2;
        color: #991b1b;
    }

    /* Пагинация */
    .pagination-container {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .pagination-btn {
        min-width: 40px;
        height: 40px;
        padding: 0 12px;
        border: 1px solid #e2e8f0;
        background: white;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .pagination-btn:hover {
            background: #f1f5f9;
            border-color: #2c5aa0;
            color: #2c5aa0;
            transform: translateY(-2px);
        }

        .pagination-btn.active {
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            color: white;
            border-color: #2c5aa0;
            box-shadow: 0 4px 10px rgba(44, 90, 160, 0.25);
        }

        .pagination-btn.disabled {
            background: #f8fafc;
            color: #94a3b8;
            cursor: not-allowed;
        }

    .pagination-arrow {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        font-size: 0.75rem;
        color: #94a3b8;
    }
</style>


    <!-- КАРТОЧКИ СТАТИСТИКИ -->
    <div class="stats-row">
        <div class="row g-3">
            <div class="col-md-3 col-6">
                <div class="card stat-card bg-primary text-white">
                    <div class="card-body">
                        <h6 class="card-title">Всего попыток</h6>
                        <h3 id="totalAttempts" class="mb-0">0</h3>
                        <i class="bi bi-list-check stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card stat-card bg-success text-white">
                    <div class="card-body">
                        <h6 class="card-title">Успешных</h6>
                        <h3 id="successfulAttempts" class="mb-0">0</h3>
                        <i class="bi bi-check-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card stat-card bg-danger text-white">
                    <div class="card-body">
                        <h6 class="card-title">Неудачных</h6>
                        <h3 id="failedAttempts" class="mb-0">0</h3>
                        <i class="bi bi-x-circle stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card stat-card bg-info text-white">
                    <div class="card-body">
                        <h6 class="card-title">Уникальных IP</h6>
                        <h3 id="uniqueIps" class="mb-0">0</h3>
                        <i class="bi bi-globe stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ФИЛЬТРЫ -->
    <div class="filter-bar">
        <div class="filter-item">
            <label><i class="bi bi-search me-1"></i> Поиск</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Email или IP...">
        </div>
        <div class="filter-item">
            <label><i class="bi bi-funnel me-1"></i> Статус</label>
            <select id="statusFilter" class="form-select">
                <option value="">Все</option>
                <option value="success">Успешные</option>
                <option value="failed">Неудачные</option>
            </select>
        </div>
        <div class="filter-item">
            <label><i class="bi bi-calendar3 me-1"></i> Дата с</label>
            <input type="date" id="startDate" class="form-control">
        </div>
        <div class="filter-item">
            <label><i class="bi bi-calendar3 me-1"></i> Дата по</label>
            <input type="date" id="endDate" class="form-control">
        </div>
        <div class="filter-item">
            <label>&nbsp;</label>
            <button id="resetFiltersBtn" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-repeat"></i> Сбросить
            </button>
        </div>
    </div>

    <!-- КНОПКИ ДЕЙСТВИЙ -->
    <div class="action-buttons-bar">
        <button id="clearLogsBtn" class="btn-clear">
            <i class="bi bi-trash3"></i> Очистить логи за 30 дней
        </button>
        <button id="exportLogsBtn" class="btn-export">
            <i class="bi bi-file-earmark-excel"></i> Экспорт в Excel
        </button>
    </div>

    <!-- ТАБЛИЦА ЛОГОВ -->
    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Дата и время</th>
                    <th>Email</th>
                    <th>IP-адрес</th>
                    <th>Статус</th>
                    <th>User Agent</th>
                </tr>
            </thead>
            <tbody id="logsTableBody">
                <tr>
                    <td colspan="5" class="table-empty-state">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">Загрузка логов...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ПАГИНАЦИЯ -->
    <div id="paginationContainer" class="pagination-container"></div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentPage = 1;
        let totalPages = 1;
        let totalCount = 0;

        // Загрузка логов
        async function loadLogs() {
            const search = document.getElementById('searchInput').value;
            const status = document.getElementById('statusFilter').value;
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;

            let url = `/Admin/GetLoginAttempts?page=${currentPage}&pageSize=20`;
            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (status) url += `&status=${status}`;
            if (startDate) url += `&startDate=${startDate}`;
            if (endDate) url += `&endDate=${endDate}`;

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (data.stats) {
                    document.getElementById('totalAttempts').innerText = data.stats.total;
                    document.getElementById('successfulAttempts').innerText = data.stats.successful;
                    document.getElementById('failedAttempts').innerText = data.stats.failed;
                    document.getElementById('uniqueIps').innerText = data.stats.uniqueIps;
                }

                renderTable(data.attempts);
                totalPages = data.totalPages;
                totalCount = data.totalCount;
                renderPagination(data.currentPage, data.totalPages, data.totalCount);

            } catch (error) {
                console.error('Ошибка загрузки:', error);
                document.getElementById('logsTableBody').innerHTML = '<tr><td colspan="5" class="table-empty-state text-danger">Ошибка загрузки данных<\/td><\/tr>';
            }
        }

        // Отображение таблицы
        function renderTable(attempts) {
            const tbody = document.getElementById('logsTableBody');
            if (!attempts || attempts.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="table-empty-state"><i class="bi bi-inbox"></i><p>Нет записей</p><\/td><\/tr>';
                return;
            }

            let html = '';
            for (const log of attempts) {
                const date = new Date(log.attemptTime).toLocaleString('ru-RU');
                const statusClass = log.isSuccessful ? 'status-success' : 'status-failed';
                const statusText = log.isSuccessful ? 'Успех' : 'Ошибка';
                const statusIcon = log.isSuccessful ? 'bi-check-circle' : 'bi-x-circle';
                const userAgent = log.userAgent ? (log.userAgent.length > 60 ? log.userAgent.substring(0, 60) + '...' : log.userAgent) : '-';

                html += `
                    <tr>
                        <td class="date-value" style="white-space: nowrap;">${date}<\/td>
                        <td><strong>${escapeHtml(log.email)}<\/strong><\/td>
                        <td><span class="ip-address">${log.ipAddress}<\/span><\/td>
                        <td><span class="status-badge ${statusClass}"><i class="bi ${statusIcon} me-1"></i> ${statusText}<\/span><\/td>
                        <td class="user-agent" title="${escapeHtml(log.userAgent || '')}">${escapeHtml(userAgent)}<\/td>
                    </tr>
                `;
            }
            tbody.innerHTML = html;
        }

        // Пагинация
        function renderPagination(current, total, totalCount) {
            const container = document.getElementById('paginationContainer');

            // Удаляем старый блок информации
            $('.pagination-info').remove();

            if (total <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = '';

            // Кнопка "Назад"
            if (current > 1) {
                html += `<button class="pagination-btn pagination-arrow" data-page="${current - 1}">‹</button>`;
            } else {
                html += `<button class="pagination-btn disabled" disabled>‹</button>`;
            }

            // Первая страница
            if (current > 2) {
                html += `<button class="pagination-btn" data-page="1">1</button>`;
                if (current > 3) {
                    html += `<span class="pagination-btn disabled">...</span>`;
                }
            }

            // Страницы вокруг текущей
            const startPage = Math.max(1, current - 1);
            const endPage = Math.min(total, current + 1);

            for (let i = startPage; i <= endPage; i++) {
                html += `<button class="pagination-btn ${current === i ? 'active' : ''}" data-page="${i}">${i}</button>`;
            }

            // Последняя страница
            if (current < total - 1) {
                if (current < total - 2) {
                    html += `<span class="pagination-btn disabled">...</span>`;
                }
                html += `<button class="pagination-btn" data-page="${total}">${total}</button>`;
            }

            // Кнопка "Вперёд"
            if (current < total) {
                html += `<button class="pagination-btn pagination-arrow" data-page="${current + 1}">›</button>`;
            } else {
                html += `<button class="pagination-btn disabled" disabled>›</button>`;
            }

            container.innerHTML = html;

            // Информация о страницах
            const startItem = (current - 1) * 20 + 1;
            const endItem = Math.min(current * 20, totalCount);
            $(container).after(`
                <div class="pagination-info">
                    Показано ${startItem}-${endItem} из ${totalCount} записей
                </div>
            `);

            // Обработчики кнопок
            document.querySelectorAll('.pagination-btn[data-page]').forEach(btn => {
                btn.removeEventListener('click', paginationClickHandler);
                btn.addEventListener('click', paginationClickHandler);
            });
        }

        function paginationClickHandler(e) {
            e.preventDefault();
            const newPage = parseInt(this.getAttribute('data-page'));
            if (!isNaN(newPage) && newPage !== currentPage) {
                currentPage = newPage;
                loadLogs();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        // Сброс фильтров
        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';

            const endDate = new Date();
            const startDate = new Date();
            startDate.setDate(startDate.getDate() - 30);
            document.getElementById('startDate').value = startDate.toISOString().slice(0,10);
            document.getElementById('endDate').value = endDate.toISOString().slice(0,10);

            currentPage = 1;
            loadLogs();
        }

        // Очистка логов
        document.getElementById('clearLogsBtn').addEventListener('click', async function() {
            if (!confirm('Вы уверены, что хотите удалить все логи старше 30 дней? Это действие нельзя отменить.')) return;

            const btn = this;
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Удаление...';

            try {
                const response = await fetch('/Admin/DeleteOldLogins', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    alert(result.message);
                    currentPage = 1;
                    loadLogs();
                } else {
                    alert('Ошибка при очистке логов');
                }
            } catch (error) {
                alert('Ошибка при очистке логов');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        });

        // Экспорт в Excel
        document.getElementById('exportLogsBtn').addEventListener('click', async function() {
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            let url = '/Admin/ExportLoginAttempts';
            const params = [];
            if (startDate) params.push(`startDate=${startDate}`);
            if (endDate) params.push(`endDate=${endDate}`);
            if (params.length) url += '?' + params.join('&');

            const btn = this;
            const originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Экспорт...';

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (!data || data.length === 0) {
                    alert('Нет данных для экспорта');
                    return;
                }

                const exportData = data.map(item => ({
                    'Email': item.email,
                    'Дата и время': new Date(item.attemptTime).toLocaleString('ru-RU'),
                    'IP-адрес': item.ipAddress,
                    'Статус': item.status,
                    'User Agent': item.userAgent
                }));

                const ws = XLSX.utils.json_to_sheet(exportData);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, 'Логи входов');
                XLSX.writeFile(wb, `login_logs_${new Date().toISOString().slice(0,10)}.xlsx`);
            } catch (error) {
                console.error('Ошибка экспорта:', error);
                alert('Ошибка при экспорте');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        });

        // Обработчики событий
        document.getElementById('resetFiltersBtn').addEventListener('click', resetFilters);

        document.getElementById('searchInput').addEventListener('input', function() { currentPage = 1; loadLogs(); });
        document.getElementById('statusFilter').addEventListener('change', function() { currentPage = 1; loadLogs(); });
        document.getElementById('startDate').addEventListener('change', function() { currentPage = 1; loadLogs(); });
        document.getElementById('endDate').addEventListener('change', function() { currentPage = 1; loadLogs(); });

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Установка дат по умолчанию (последние 30 дней)
        function setDefaultDates() {
            const endDate = new Date();
            const startDate = new Date();
            startDate.setDate(startDate.getDate() - 30);
            document.getElementById('startDate').value = startDate.toISOString().slice(0,10);
            document.getElementById('endDate').value = endDate.toISOString().slice(0,10);
        }

        setDefaultDates();
        loadLogs();
    </script>
}