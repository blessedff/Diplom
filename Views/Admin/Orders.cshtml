@model IEnumerable<StationeryShop.Models.Order>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Управление заказами";
}

<h2 class="mb-4"><i class="bi bi-bag"></i> Управление заказами</h2>

<div class="table-responsive">
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Клиент</th>
                <th>Дата</th>
                <th>Сумма</th>
                <th>Статус</th>
                <th>Адрес доставки</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.OrderID</td>
                    <td>@order.Customer?.FullName</td>
                    <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.TotalAmount.ToString("0.00") byn</td>
                    <td>
                        <select class="form-select form-select-sm status-select" data-order-id="@order.OrderID">
                            <option value="Принят" selected="@(order.Status == "Принят")">Принят</option>
                            <option value="Сформирован" selected="@(order.Status == "Сформирован")">Сформирован</option>
                            <option value="Готов к выдаче" selected="@(order.Status == "Готов к выдаче")">Готов к выдаче</option>
                            <option value="Выполнен" selected="@(order.Status == "Выполнен")">Выполнен</option>
                            <option value="Отменен" selected="@(order.Status == "Отменен")">Отменен</option>
                        </select>
                    </td>
                    <td>@order.ShippingAddress</td>
                    <td>
                        <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.OrderID" 
                           class="btn btn-sm btn-info" title="Детали">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Обновление статуса заказа
        document.querySelectorAll('.status-select').forEach(select => {
            select.addEventListener('change', function() {
                const orderId = this.dataset.orderId;
                const status = this.value;
                
                fetch('/Admin/UpdateOrderStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `orderId=${orderId}&status=${status}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Статус заказа обновлен', 'success');
                    } else {
                        showNotification(data.message, 'error');
                        // Возвращаем предыдущее значение
                        this.value = this.oldValue;
                    }
                })
                .catch(error => {
                    showNotification('Ошибка при обновлении статуса', 'error');
                    this.value = this.oldValue;
                });
                
                // Сохраняем предыдущее значение
                this.oldValue = this.value;
            });
            
            // Инициализируем предыдущее значение
            select.oldValue = select.value;
        });

        function showNotification(message, type) {
            // Простая реализация уведомления
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const alert = document.createElement('div');
            alert.className = `alert ${alertClass} alert-dismissible fade show`;
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.querySelector('h2').after(alert);
            
            // Автоматически скрываем через 3 секунды
            setTimeout(() => {
                alert.remove();
            }, 3000);
        }
    </script>
}