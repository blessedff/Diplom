@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Управление вопросами о товарах";
}

@using StationeryShop.Models
@{
    var products = ViewBag.Products as List<dynamic> ?? new List<dynamic>();
}

<style>
    /* Общие стили страницы */
    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 0;
    }


    .stats-row {
        margin-bottom: 25px;
    }

    .stat-card {
        border: none;
        border-radius: 16px;
        transition: all 0.3s ease;
        overflow: hidden;
        position: relative;
        height: 100%;
        cursor: pointer;
    }


        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .stat-icon {
        font-size: 2rem;
        opacity: 0.15;
        position: absolute;
        bottom: 12px;
        right: 15px;
    }

    /* Фильтры (единый стиль) */
    .filter-bar {
        background: white;
        border-radius: 20px;
        padding: 20px 24px;
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 15px;
        border: 1px solid #eef2f6;
    }

    .filter-item {
        flex: 1;
        min-width: 150px;
    }

        .filter-item label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #64748b;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            display: block;
        }

        .filter-item input,
        .filter-item select {
            width: 100%;
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            font-size: 0.85rem;
        }

            .filter-item input:focus,
            .filter-item select:focus {
                border-color: #2c5aa0;
                box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
                outline: none;
            }

    /* Список вопросов (карточки, не таблица) */
    .questions-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 25px;
    }

    .question-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #eef2f6;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .question-card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        }

    /* Шапка карточки */
    .question-header {
        background: #f8fafc;
        padding: 15px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        border-bottom: 1px solid #eef2f6;
    }

    .product-info {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .product-info i {
            color: #2c5aa0;
            font-size: 1.1rem;
        }

    .product-name {
        font-weight: 600;
        color: #1a1a2e;
    }

    .question-meta {
        display: flex;
        gap: 15px;
        font-size: 0.75rem;
        color: #64748b;
    }

    /* Бейджи статусов */
    .status-pending {
        background: #fef3c7;
        color: #92400e;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .status-answered {
        background: #d1fae5;
        color: #065f46;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    /* Тело карточки */
    .question-body {
        padding: 20px;
    }

    .question-user {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 1px solid #eef2f6;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .user-avatar i {
            font-size: 1.2rem;
            color: white;
        }

    .user-info {
        flex: 1;
    }

    .user-name {
        font-weight: 600;
        color: #1a1a2e;
    }

    .user-email {
        font-size: 0.7rem;
        color: #64748b;
    }

    .question-text {
        background: #f8fafc;
        border-radius: 16px;
        padding: 15px;
        margin-bottom: 20px;
    }

        .question-text i {
            color: #2c5aa0;
            margin-right: 8px;
        }

        .question-text p {
            margin: 0;
            line-height: 1.5;
            color: #334155;
        }

    /* Блок ответа */
    .answer-section {
        background: #f8fafc;
        border-radius: 16px;
        padding: 15px;
        margin-top: 10px;
    }

    .answer-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: #10b981;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .answer-text {
        background: white;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 15px;
        font-size: 0.85rem;
        color: #334155;
    }

    .answer-date {
        font-size: 0.65rem;
        color: #64748b;
        text-align: right;
    }

    .answer-form textarea {
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px;
        font-size: 0.85rem;
        resize: vertical;
    }

        .answer-form textarea:focus {
            border-color: #2c5aa0;
            outline: none;
        }

    /* Кнопки действий */
    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        justify-content: flex-end;
    }

    .btn-answer {
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        border-radius: 30px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.8rem;
        color: white;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-answer:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(16, 185, 129, 0.3);
        }

    .btn-delete {
        background: none;
        border: 1px solid #ef4444;
        color: #ef4444;
        border-radius: 30px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-delete:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: none;
        border: 1px solid #f59e0b;
        color: #d97706;
        border-radius: 30px;
        padding: 8px 20px;
        font-weight: 600;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-edit:hover {
            background: #f59e0b;
            color: white;
            transform: translateY(-2px);
        }

    /* Пагинация */
    .pagination-container {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 20px;
        flex-wrap: wrap;
    }

    .pagination-btn {
        min-width: 40px;
        height: 40px;
        padding: 0 12px;
        border: 1px solid #e2e8f0;
        background: white;
        border-radius: 12px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .pagination-btn:hover {
            background: #f1f5f9;
            border-color: #2c5aa0;
            color: #2c5aa0;
            transform: translateY(-2px);
        }

        .pagination-btn.active {
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            color: white;
            border-color: #2c5aa0;
            box-shadow: 0 4px 10px rgba(44, 90, 160, 0.25);
        }

        .pagination-btn.disabled {
            background: #f8fafc;
            color: #94a3b8;
            cursor: not-allowed;
        }

    .pagination-arrow {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .pagination-info {
        text-align: center;
        margin-top: 15px;
        font-size: 0.75rem;
        color: #94a3b8;
    }

    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        border: 1px solid #eef2f6;
    }

        .empty-state i {
            font-size: 4rem;
            color: #cbd5e1;
            margin-bottom: 15px;
        }

    /* Модальное окно */
    .answer-modal .modal-content {
        border-radius: 24px;
        overflow: hidden;
    }

    .answer-modal .modal-header {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        border: none;
        padding: 18px 24px;
    }

        .answer-modal .modal-header .btn-close {
            filter: brightness(0) invert(1);
        }

    .answer-modal .modal-body {
        padding: 24px;
    }

    .answer-modal .original-question {
        background: #f8fafc;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 20px;
        border-left: 4px solid #2c5aa0;
    }

    .answer-modal .original-question-label {
        font-size: 0.7rem;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Анимация */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .question-card {
        animation: fadeInUp 0.3s ease-out;
    }
</style>



    <!-- КАРТОЧКИ СТАТИСТИКИ (единый стиль) -->
    <div class="stats-row">
        <div class="row g-3">
            <div class="col-md-4 col-6">
                <div class="card stat-card bg-primary text-white" onclick="applyStatusFilter('')">
                    <div class="card-body">
                        <h6 class="card-title">Всего вопросов</h6>
                        <h3 id="totalCount" class="mb-0">0</h3>
                        <i class="bi bi-chat-dots stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="card stat-card bg-warning text-white" onclick="applyStatusFilter('pending')">
                    <div class="card-body">
                        <h6 class="card-title">Ожидают ответа</h6>
                        <h3 id="pendingCount" class="mb-0">0</h3>
                        <i class="bi bi-clock-history stat-icon"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="card stat-card bg-success text-white" onclick="applyStatusFilter('answered')">
                    <div class="card-body">
                        <h6 class="card-title">Отвечено</h6>
                        <h3 id="answeredCount" class="mb-0">0</h3>
                        <i class="bi bi-check-circle stat-icon"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ФИЛЬТРЫ (единый стиль) -->
    <div class="filter-bar">
        <div class="filter-item">
            <label><i class="bi bi-search me-1"></i> Поиск</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Поиск по вопросу или имени...">
        </div>
        <div class="filter-item">
            <label><i class="bi bi-funnel me-1"></i> Статус</label>
            <select id="statusFilter" class="form-select">
                <option value="">Все</option>
                <option value="pending">Ожидают ответа</option>
                <option value="answered">Отвечено</option>
            </select>
        </div>
        <div class="filter-item">
            <label><i class="bi bi-sort-down me-1"></i> Сортировка</label>
            <select id="sortFilter" class="form-select">
                <option value="newest">Сначала новые</option>
                <option value="oldest">Сначала старые</option>
            </select>
        </div>
        <div class="filter-item">
            <label>&nbsp;</label>
            <button id="resetFiltersBtn" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-repeat me-1"></i> Сбросить
            </button>
        </div>
    </div>

    <!-- СПИСОК ВОПРОСОВ -->
    <div id="questionsContainer" class="questions-list">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Загрузка вопросов...</p>
        </div>
    </div>

    <!-- ПАГИНАЦИЯ -->
    <div id="paginationContainer" class="pagination-container"></div>
</div>

<!-- МОДАЛЬНОЕ ОКНО ДЛЯ ОТВЕТА/РЕДАКТИРОВАНИЯ -->
<div class="modal fade answer-modal" id="answerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="answerModalTitle">
                    <i class="bi bi-reply-fill me-2"></i> Ответ на вопрос
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editQuestionId">

                <!-- Оригинальный вопрос -->
                <div class="original-question">
                    <div class="original-question-label">
                        <i class="bi bi-question-circle me-1"></i> Вопрос пользователя
                    </div>
                    <div class="fw-bold" id="originalQuestionText"></div>
                    <div class="mt-2 text-muted small" id="questionUserInfo"></div>
                </div>

                <!-- Форма ответа -->
                <div class="mb-3">
                    <label class="form-label fw-bold">Ваш ответ</label>
                    <textarea id="answerText" class="form-control" rows="5" placeholder="Введите ответ на вопрос..."></textarea>
                    <small class="text-muted mt-1 d-block"><i class="bi bi-info-circle"></i> После сохранения пользователь получит уведомление на email</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" id="saveAnswerBtn" class="btn btn-primary">
                    <i class="bi bi-send me-1"></i> Отправить ответ
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Глобальные переменные
        let currentPage = 1;
        let totalPages = 1;
        let totalCount = 0;

        // Параметры фильтрации
        let currentSearch = '';
        let currentStatus = '';
        let currentSort = 'newest';

        // Применение фильтра по статусу из карточки
        function applyStatusFilter(status) {
            if (status === '') {
                document.getElementById('statusFilter').value = '';
            } else {
                document.getElementById('statusFilter').value = status;
            }
            currentPage = 1;
            loadQuestions();
        }

        // Загрузка вопросов с сервера
        async function loadQuestions() {
            currentSearch = document.getElementById('searchInput').value;
            currentStatus = document.getElementById('statusFilter').value;
            currentSort = document.getElementById('sortFilter').value;

            let url = `/Admin/GetProductQuestionsAdmin?page=${currentPage}&pageSize=10`;
            if (currentSearch) url += `&search=${encodeURIComponent(currentSearch)}`;
            if (currentStatus) url += `&status=${currentStatus}`;
            if (currentSort) url += `&sort=${currentSort}`;

            const container = document.getElementById('questionsContainer');
            container.innerHTML = `
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Загрузка вопросов...</p>
                </div>
            `;

            try {
                const response = await fetch(url);
                const data = await response.json();

                if (data.stats) {
                    document.getElementById('totalCount').innerText = data.stats.total;
                    document.getElementById('pendingCount').innerText = data.stats.pending;
                    document.getElementById('answeredCount').innerText = data.stats.answered;
                }

                totalPages = data.totalPages;
                totalCount = data.totalCount;
                renderPagination(data.currentPage, data.totalPages, data.totalCount);
                renderQuestions(data.questions);

            } catch (error) {
                console.error('Ошибка загрузки:', error);
                document.getElementById('questionsContainer').innerHTML = `
                    <div class="alert alert-danger text-center">
                        <i class="bi bi-exclamation-triangle"></i> Ошибка при загрузке вопросов
                    </div>
                `;
            }
        }

        // Отображение списка вопросов
        function renderQuestions(questions) {
            const container = document.getElementById('questionsContainer');

            if (!questions || questions.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <i class="bi bi-chat-dots"></i>
                        <h5>Вопросов не найдено</h5>
                        <p class="text-muted">Попробуйте изменить параметры фильтрации</p>
                    </div>
                `;
                return;
            }

            let html = '';
            for (const q of questions) {
                const questionDate = new Date(q.questionDate).toLocaleString('ru-RU');
                const isAnswered = q.isAnswered;

                html += `
                    <div class="question-card" data-id="${q.id}">
                        <div class="question-header">
                            <div class="product-info">
                                <i class="bi bi-box-seam"></i>
                                <span class="product-name">${escapeHtml(q.productName)}</span>
                            </div>
                            <div class="question-meta">
                                <span class="${isAnswered ? 'status-answered' : 'status-pending'}">
                                    ${isAnswered ? 'Отвечено' : 'Ожидает ответа'}
                                </span>
                                <span><i class="bi bi-calendar3"></i> ${questionDate}</span>
                            </div>
                        </div>
                        <div class="question-body">
                            <div class="question-user">
                                <div class="user-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <div class="user-info">
                                    <div class="user-name">${escapeHtml(q.customerName)}</div>
                                    <div class="user-email">${escapeHtml(q.customerEmail)}</div>
                                </div>
                            </div>
                            <div class="question-text">
                                <i class="bi bi-question-circle"></i>
                                <p>${escapeHtml(q.question)}</p>
                            </div>
                `;

                if (isAnswered && q.answer) {
                    const answerDate = new Date(q.answerDate).toLocaleString('ru-RU');
                    html += `
                        <div class="answer-section">
                            <div class="answer-label">
                                <i class="bi bi-reply-fill"></i> Ответ администратора
                            </div>
                            <div class="answer-text">${escapeHtml(q.answer)}</div>
                            <div class="answer-date">${answerDate}</div>
                            <div class="action-buttons">
                                <button class="btn-edit" onclick="openEditModal(${q.id}, '${escapeHtml(q.answer).replace(/'/g, "\\'")}', '${escapeHtml(q.question).replace(/'/g, "\\'")}', '${escapeHtml(q.customerName).replace(/'/g, "\\'")}', '${escapeHtml(q.customerEmail).replace(/'/g, "\\'")}')">
                                    <i class="bi bi-pencil"></i> Редактировать
                                </button>
                                <button class="btn-delete" onclick="deleteQuestion(${q.id})">
                                    <i class="bi bi-trash"></i> Удалить
                                </button>
                            </div>
                        </div>
                    `;
                } else {
                    html += `
                        <div class="answer-section">
                            <div class="action-buttons" style="justify-content: flex-start;">
                                <button class="btn-answer" onclick="openAnswerModal(${q.id}, '${escapeHtml(q.question).replace(/'/g, "\\'")}', '${escapeHtml(q.customerName).replace(/'/g, "\\'")}', '${escapeHtml(q.customerEmail).replace(/'/g, "\\'")}')">
                                    <i class="bi bi-reply"></i> Ответить
                                </button>
                                <button class="btn-delete" onclick="deleteQuestion(${q.id})">
                                    <i class="bi bi-trash"></i> Удалить
                                </button>
                            </div>
                        </div>
                    `;
                }

                html += `</div></div>`;
            }

            container.innerHTML = html;
        }

        // Модальное окно для ответа
        function openAnswerModal(questionId, questionText, customerName, customerEmail) {
            document.getElementById('answerModalTitle').innerHTML = '<i class="bi bi-reply-fill me-2"></i> Ответ на вопрос';
            document.getElementById('editQuestionId').value = questionId;
            document.getElementById('originalQuestionText').innerHTML = escapeHtml(questionText);
            document.getElementById('questionUserInfo').innerHTML = `<i class="bi bi-person-circle me-1"></i> ${escapeHtml(customerName)} (${escapeHtml(customerEmail)})`;
            document.getElementById('answerText').value = '';
            new bootstrap.Modal(document.getElementById('answerModal')).show();
        }

        // Модальное окно для редактирования
        function openEditModal(questionId, currentAnswer, questionText, customerName, customerEmail) {
            document.getElementById('answerModalTitle').innerHTML = '<i class="bi bi-pencil-square me-2"></i> Редактировать ответ';
            document.getElementById('editQuestionId').value = questionId;
            document.getElementById('originalQuestionText').innerHTML = escapeHtml(questionText);
            document.getElementById('questionUserInfo').innerHTML = `<i class="bi bi-person-circle me-1"></i> ${escapeHtml(customerName)} (${escapeHtml(customerEmail)})`;
            document.getElementById('answerText').value = currentAnswer;
            new bootstrap.Modal(document.getElementById('answerModal')).show();
        }

        // Сохранение ответа
        async function saveAnswer() {
            const questionId = document.getElementById('editQuestionId').value;
            const answerText = document.getElementById('answerText').value.trim();

            if (!answerText) {
                showToast('Введите текст ответа', 'error');
                return;
            }

            const modalElement = document.getElementById('answerModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            modal.hide();

            const saveBtn = document.getElementById('saveAnswerBtn');
            const originalText = saveBtn.innerHTML;
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Сохранение...';

            try {
                const response = await fetch('/Admin/AnswerQuestion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: parseInt(questionId), answer: answerText })
                });
                const result = await response.json();

                if (result.success) {
                    showToast('Ответ успешно сохранён! Пользователь получит уведомление.', 'success');
                    loadQuestions();
                } else {
                    showToast('Ошибка: ' + result.message, 'error');
                }
            } catch (error) {
                showToast('Ошибка при сохранении ответа', 'error');
            } finally {
                saveBtn.disabled = false;
                saveBtn.innerHTML = originalText;
            }
        }

        // Удаление вопроса
        async function deleteQuestion(questionId) {
            if (!confirm('Вы уверены, что хотите удалить этот вопрос? Это действие нельзя отменить.')) return;

            try {
                const response = await fetch('/Admin/DeleteQuestion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id: questionId })
                });
                const result = await response.json();

                if (result.success) {
                    showToast('Вопрос удалён', 'success');
                    loadQuestions();
                } else {
                    showToast('Ошибка: ' + result.message, 'error');
                }
            } catch (error) {
                showToast('Ошибка при удалении вопроса', 'error');
            }
        }

        // Уведомления
        function showToast(message, type) {
            const toastClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            const toast = document.createElement('div');
            toast.className = `alert ${toastClass} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
            toast.style.zIndex = '9999';
            toast.style.minWidth = '300px';
            toast.innerHTML = `
                <i class="bi ${icon} me-2"></i>
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // Пагинация
        function renderPagination(current, total, totalCount) {
            const container = document.getElementById('paginationContainer');
            $('.pagination-info').remove();

            if (total <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = '';

            if (current > 1) {
                html += `<button class="pagination-btn pagination-arrow" data-page="${current - 1}">‹</button>`;
            } else {
                html += `<button class="pagination-btn disabled" disabled>‹</button>`;
            }

            if (current > 2) {
                html += `<button class="pagination-btn" data-page="1">1</button>`;
                if (current > 3) html += `<span class="pagination-btn disabled">...</span>`;
            }

            const startPage = Math.max(2, current - 1);
            const endPage = Math.min(total - 1, current + 1);

            for (let i = startPage; i <= endPage; i++) {
                html += `<button class="pagination-btn ${i === current ? 'active' : ''}" data-page="${i}">${i}</button>`;
            }

            if (current < total) {
                if (current < total - 2) html += `<span class="pagination-btn disabled">...</span>`;
                html += `<button class="pagination-btn" data-page="${total}">${total}</button>`;
            }

            if (current < total) {
                html += `<button class="pagination-btn pagination-arrow" data-page="${current + 1}">›</button>`;
            } else {
                html += `<button class="pagination-btn disabled" disabled>›</button>`;
            }

            container.innerHTML = html;

            const startItem = (current - 1) * 10 + 1;
            const endItem = Math.min(current * 10, totalCount);
            $(container).after(`<div class="pagination-info">Показано ${startItem}-${endItem} из ${totalCount} вопросов</div>`);

            document.querySelectorAll('.pagination-btn[data-page]').forEach(btn => {
                btn.removeEventListener('click', paginationHandler);
                btn.addEventListener('click', paginationHandler);
            });
        }

        function paginationHandler(e) {
            e.preventDefault();
            const newPage = parseInt(this.getAttribute('data-page'));
            if (!isNaN(newPage) && newPage !== currentPage) {
                currentPage = newPage;
                loadQuestions();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }

        // Сброс фильтров
        function resetFilters() {
            document.getElementById('searchInput').value = '';
            document.getElementById('statusFilter').value = '';
            document.getElementById('sortFilter').value = 'newest';
            currentPage = 1;
            loadQuestions();
        }

        // Обработчики событий
        function bindFilterEvents() {
            document.getElementById('searchInput').addEventListener('input', function() {
                currentPage = 1;
                loadQuestions();
            });
            document.getElementById('statusFilter').addEventListener('change', function() {
                currentPage = 1;
                loadQuestions();
            });
            document.getElementById('sortFilter').addEventListener('change', function() {
                currentPage = 1;
                loadQuestions();
            });
            document.getElementById('resetFiltersBtn').addEventListener('click', resetFilters);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Инициализация
        document.addEventListener('DOMContentLoaded', function() {
            bindFilterEvents();
            loadQuestions();
            document.getElementById('saveAnswerBtn').addEventListener('click', saveAnswer);
            document.getElementById('answerText').addEventListener('keydown', function(e) {
                if (e.ctrlKey && e.key === 'Enter') {
                    e.preventDefault();
                    saveAnswer();
                }
            });
        });
    </script>
}