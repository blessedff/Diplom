@model IEnumerable<StationeryShop.Models.Product>

@{
    ViewData["Title"] = "Управление товарами";
}

<h2 class="mb-4"><i class="bi bi-box-seam"></i> Управление товарами</h2>

<div class="d-flex justify-content-between mb-3">
    <a asp-controller="Products" asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Добавить товар
    </a>
    <span class="text-muted">Всего товаров: @Model.Count()</span>
</div>

<div class="table-responsive">
    <table class="table table-striped">
        <thead class="table-dark">
            <tr>
                <th>Фото</th>
                <th>Название</th>
                <th>Категория</th>
                <th>Цена</th>
                <th>Запас</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>
                        @if (product.PhotoBase64 != null)
                        {
                            <img src="data:image/png;base64,@product.PhotoBase64" 
                                 alt="Фото" class="img-thumbnail" 
                                 style="width: 50px; height: 50px; object-fit: cover;">
                        }
                        else
                        {
                            <span class="text-muted">Нет</span>
                        }
                    </td>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name</td>
                    <td>@product.Price.ToString("0.00") byn</td>
                    <td>
                        <div class="input-group input-group-sm" style="width: 120px;">
                            <input type="number" class="form-control stock-input" 
                                   value="@product.StockQuantity" min="0"
                                   data-product-id="@product.ProductID">
                            <button class="btn btn-outline-primary update-stock-btn" type="button">
                                <i class="bi bi-arrow-clockwise"></i>
                            </button>
                        </div>
                    </td>
                    <td>
                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.ProductID" 
                           class="btn btn-sm btn-warning" title="Редактировать">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" 
                           class="btn btn-sm btn-info" title="Просмотр">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Обновление запаса товара
        document.querySelectorAll('.update-stock-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const input = this.previousElementSibling;
                const productId = input.dataset.productId;
                const newStock = parseInt(input.value);
                
                if (isNaN(newStock) || newStock < 0) {
                    showNotification('Введите корректное количество', 'error');
                    return;
                }
                
                fetch('/Admin/UpdateProductStock', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `productId=${productId}&newStock=${newStock}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Запас товара обновлен', 'success');
                        input.value = data.newStock;
                    } else {
                        showNotification(data.message, 'error');
                    }
                })
                .catch(error => {
                    showNotification('Ошибка при обновлении запаса', 'error');
                });
            });
        });

        function showNotification(message, type) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const alert = document.createElement('div');
            alert.className = `alert ${alertClass} alert-dismissible fade show`;
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            document.querySelector('h2').after(alert);
            
            setTimeout(() => {
                alert.remove();
            }, 3000);
        }
    </script>
}