@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Управление отзывами";
}

@model IEnumerable<StationeryShop.Models.Review>

<style>
    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1rem;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 0;
        width: 50px;
        height: 3px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 2px;
    }

    /* Карточки статистики */
    .stat-card {
        border: none;
        border-radius: 16px;
        padding: 15px 20px;
        transition: all 0.2s ease;
        height: 100%;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .stat-card:hover {
        transform: translateY(-3px);
    }

    .stat-card .stat-icon {
        font-size: 1.8rem;
        opacity: 0.12;
        position: absolute;
        bottom: 10px;
        right: 15px;
    }

    .stat-card .stat-value {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 3px;
    }

    .stat-card .stat-label {
        font-size: 0.75rem;
        opacity: 0.85;
    }

    /* Фильтры */
    .filter-bar {
        background: white;
        border-radius: 16px;
        padding: 15px 20px;
        margin-bottom: 25px;
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 15px;
        border: 1px solid #e9ecef;
    }

    .filter-item {
        flex: 1;
        min-width: 150px;
    }

    .filter-item label {
        font-size: 0.7rem;
        font-weight: 600;
        color: #6c757d;
        margin-bottom: 4px;
        display: block;
    }

    .filter-item select, .filter-item input {
        width: 100%;
        padding: 8px 12px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        font-size: 0.85rem;
    }

    /* Таблица */
    .reviews-table {
        border-radius: 16px;
        overflow: hidden;
    }

    .reviews-table thead th {
        background: #f8f9fa;
        font-weight: 600;
        padding: 12px;
        border-bottom: 2px solid #e9ecef;
    }

    .reviews-table tbody td {
        padding: 10px 12px;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
    }

    .reviews-table tbody tr:hover {
        background: #f8f9fa;
    }

    /* Бейджи статусов */
    .status-badge {
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-pending {
        background: #fff3cd;
        color: #856404;
    }

    .status-approved {
        background: #d4edda;
        color: #155724;
    }

    .status-rejected {
        background: #f8d7da;
        color: #721c24;
    }

    /* Звёзды */
    .stars {
        color: #ffc107;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    /* Кнопки действий */
    .action-buttons {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
    }

    .btn-icon {
        padding: 4px 8px;
        border-radius: 8px;
        font-size: 0.8rem;
        transition: all 0.2s ease;
    }

    .btn-icon:hover {
        transform: translateY(-2px);
    }

    /* Модальное окно */
    .modal-content {
        border-radius: 20px;
    }

    .review-comment {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 12px;
        margin: 10px 0;
    }
</style>

<div class="reviews-container">


    <!-- КАРТОЧКИ СТАТИСТИКИ -->
    <div class="row g-3 mb-4">
        <div class="col-md-4 col-6">
            <div class="card stat-card bg-warning text-white" data-status="pending">
                <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
                <div class="stat-value" id="pendingCount">@ViewBag.PendingCount</div>
                <div class="stat-label">На модерации</div>
            </div>
        </div>
        <div class="col-md-4 col-6">
            <div class="card stat-card bg-success text-white" data-status="approved">
                <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
                <div class="stat-value" id="approvedCount">@ViewBag.ApprovedCount</div>
                <div class="stat-label">Одобрено</div>
            </div>
        </div>
        <div class="col-md-4 col-6">
            <div class="card stat-card bg-danger text-white" data-status="rejected">
                <div class="stat-icon"><i class="bi bi-x-circle"></i></div>
                <div class="stat-value" id="rejectedCount">@ViewBag.RejectedCount</div>
                <div class="stat-label">Отклонено</div>
            </div>
        </div>
    </div>

    <!-- ФИЛЬТРЫ -->
    <div class="filter-bar">
        <div class="filter-item">
            <label><i class="bi bi-funnel me-1"></i> Статус</label>
            <select id="statusFilter" class="form-select">
                <option value="all" selected="@(ViewBag.CurrentStatus == "all")">Все</option>
                <option value="pending" selected="@(ViewBag.CurrentStatus == "pending")">На модерации</option>
                <option value="approved" selected="@(ViewBag.CurrentStatus == "approved")">Одобренные</option>
                <option value="rejected" selected="@(ViewBag.CurrentStatus == "rejected")">Отклонённые</option>
            </select>
        </div>
        <div class="filter-item">
            <label><i class="bi bi-tag me-1"></i> Тип</label>
            <select id="typeFilter" class="form-select">
                <option value="all" selected="@(ViewBag.CurrentType == "all")">Все</option>
                <option value="product" selected="@(ViewBag.CurrentType == "product")">На товары</option>
                <option value="shop" selected="@(ViewBag.CurrentType == "shop")">На магазин</option>
            </select>
        </div>
        <div class="filter-item">
            <label><i class="bi bi-search me-1"></i> Поиск</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Email пользователя..." value="@ViewBag.Search">
        </div>

    </div>

    <!-- ТАБЛИЦА ОТЗЫВОВ -->
    <div class="table-responsive">
        <table class="table reviews-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Товар</th>
                    <th>Пользователь</th>
                    <th>Оценка</th>
                    <th>Отзыв</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td>@review.Id</td>
                            <td>
                                @if (review.ProductId != null)
                                {
                                    <span class="badge bg-info">
                                        <i class="bi bi-box-seam me-1"></i> @(review.Product?.Name ?? "Товар удалён")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        <i class="bi bi-shop me-1"></i> Отзыв о магазине
                                    </span>
                                }
                            </td>
                            <td>
                                <strong>@(review.Customer?.FullName ?? "Пользователь")</strong><br>
                                <small class="text-muted">@(review.Customer?.Email ?? "")</small>
                            </td>
                            <td class="stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star"></i>
                                    }
                                }
                            </td>
                            <td style="max-width: 250px;">
                                <div class="review-comment">
                                    @review.Comment
                                </div>
                                @if (!string.IsNullOrEmpty(review.AdminResponse))
                                {
                                    <div class="mt-2 small text-primary">
                                        <i class="bi bi-reply-fill me-1"></i> Ответ: @review.AdminResponse
                                    </div>
                                }
                            </td>
                            <td>
                                @if (!review.IsApproved && !review.IsRejected)
                                {
                                    <span class="status-badge status-pending">На модерации</span>
                                }
                                else if (review.IsApproved)
                                {
                                    <span class="status-badge status-approved">Одобрен</span>
                                }
                                else if (review.IsRejected)
                                {
                                    <span class="status-badge status-rejected">Отклонён</span>
                                }
                            </td>
                            <td>@review.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="action-buttons">
                                    @if (!review.IsApproved && !review.IsRejected)
                                    {
                                        <button class="btn btn-sm btn-success approve-review" data-id="@review.Id" title="Одобрить">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                        <button class="btn btn-sm btn-danger reject-review" data-id="@review.Id" title="Отклонить">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                    @if (review.IsApproved && !review.IsRejected)
                                    {
                                        <button class="btn btn-sm btn-danger reject-review" data-id="@review.Id" title="Отклонить">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    }
                                    @if (review.IsRejected && !review.IsApproved)
                                    {
                                        <button class="btn btn-sm btn-success approve-review" data-id="@review.Id" title="Одобрить">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    }
                                    <button class="btn btn-sm btn-info reply-review" data-id="@review.Id" data-comment="@review.Comment" data-response="@review.AdminResponse" title="Ответить">
                                        <i class="bi bi-reply"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger delete-review" data-id="@review.Id" title="Удалить">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1"></i>
                            <p class="mt-2">Нет отзывов</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- МОДАЛЬНОЕ ОКНО ДЛЯ ОТВЕТА -->
<div class="modal fade" id="replyModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-reply-fill"></i> Ответ на отзыв</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="replyReviewId">
                <div class="mb-3">
                    <label class="form-label fw-bold">Отзыв пользователя</label>
                    <div class="bg-light p-3 rounded" id="userComment"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ваш ответ</label>
                    <textarea id="replyText" class="form-control" rows="4" placeholder="Напишите ответ на отзыв..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" id="sendReplyBtn" class="btn btn-primary">Отправить ответ</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
             function applyFilters() {
            const status = document.getElementById('statusFilter').value;
            const type = document.getElementById('typeFilter').value;
            const search = document.getElementById('searchInput').value;
            window.location.href = `/Admin/Reviews?status=${status}&type=${type}&search=${encodeURIComponent(search)}`;
        }

       
        document.getElementById('statusFilter').addEventListener('change', function() {
            applyFilters();
        });

      
        document.getElementById('typeFilter').addEventListener('change', function() {
            applyFilters();
        });

        
        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                applyFilters();
            }, 500);
        });

        
        document.querySelectorAll('.stat-card').forEach(card => {
            card.addEventListener('click', function() {
                const status = this.getAttribute('data-status');
                const type = document.getElementById('typeFilter').value;
                const search = document.getElementById('searchInput').value;
                window.location.href = `/Admin/Reviews?status=${status}&type=${type}&search=${encodeURIComponent(search)}`;
            });
        });

        // Карточки статистики как фильтр
        document.querySelectorAll('.stat-card').forEach(card => {
            card.addEventListener('click', function() {
                const status = this.getAttribute('data-status');
                const type = document.getElementById('typeFilter').value;
                const search = document.getElementById('searchInput').value;
                window.location.href = `/Admin/Reviews?status=${status}&type=${type}&search=${encodeURIComponent(search)}`;
            });
        });

        // Одобрение отзыва
        document.querySelectorAll('.approve-review').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.dataset.id;
                const response = await fetch(`/Admin/ApproveReview?id=${id}`, { method: 'POST' });
                if (response.ok) location.reload();
            });
        });

        // Отклонение отзыва
        document.querySelectorAll('.reject-review').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.dataset.id;
                const response = await fetch(`/Admin/RejectReview?id=${id}`, { method: 'POST' });
                if (response.ok) location.reload();
            });
        });

        // Удаление отзыва
        document.querySelectorAll('.delete-review').forEach(btn => {
            btn.addEventListener('click', async function() {
                const id = this.dataset.id;
                const response = await fetch(`/Admin/DeleteReview?id=${id}`, { method: 'POST' });
                if (response.ok) location.reload();
            });
        });

        // Модальное окно для ответа
        const replyModal = new bootstrap.Modal(document.getElementById('replyModal'));
        
        document.querySelectorAll('.reply-review').forEach(btn => {
            btn.addEventListener('click', function() {
                const id = this.dataset.id;
                const comment = this.dataset.comment;
                const response = this.dataset.response || '';
                
                document.getElementById('replyReviewId').value = id;
                document.getElementById('userComment').innerHTML = comment;
                document.getElementById('replyText').value = response;
                replyModal.show();
            });
        });

        // Отправка ответа
        document.getElementById('sendReplyBtn').addEventListener('click', async function() {
            const id = document.getElementById('replyReviewId').value;
            const reply = document.getElementById('replyText').value;
            
            const response = await fetch('/Admin/ReplyToReview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&reply=${encodeURIComponent(reply)}`
            });
            
            if (response.ok) {
                replyModal.hide();
                location.reload();
            }
        });

        // Enter для поиска
        document.getElementById('searchInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') document.getElementById('applyFilter').click();
        });
    </script>
}