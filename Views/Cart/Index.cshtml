@model List<StationeryShop.Models.CartItem>

@{
    ViewData["Title"] = "Корзина покупок";
}

<h2 class="mb-4">Корзина покупок</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Товар</th>
                    <th>Цена</th>
                    <th>Количество</th>
                    <th>Итого</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.Price.ToString("0.00") byn</td>
                        <td>
                            <form asp-action="UpdateQuantity" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <div class="input-group input-group-sm" style="width: 120px;">
                                    <input type="number" name="quantity" value="@item.Quantity" 
                                           min="1" max="100" class="form-control" />
                                    <button type="submit" class="btn btn-outline-primary">
                                        <i class="bi bi-arrow-clockwise"></i>
                                    </button>
                                </div>
                            </form>
                        </td>
                        <td>@item.TotalPrice.ToString("0.00") byn</td>
                        <td>
                            <form asp-action="RemoveFromCart" method="post" class="d-inline">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Удалить
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-active">
                    <td colspan="3" class="text-end"><strong>Общая сумма:</strong></td>
                    <td colspan="2"><strong>@ViewBag.TotalPrice.ToString("0.00") byn</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Продолжить покупки
        </a>
        
        <div>
            <form asp-action="ClearCart" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-cart-x"></i> Очистить корзину
                </button>
            </form>
            
<a asp-controller="Orders" asp-action="Create" class="btn btn-success ms-2">
    <i class="bi bi-bag-check"></i> Оформить заказ
</a>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-cart-x" style="font-size: 4rem; color: #6c757d;"></i>
        <h3 class="mt-3">Ваша корзина пуста</h3>
        <p class="text-muted">Добавьте товары из каталога, чтобы сделать заказ</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-arrow-left"></i> Перейти к покупкам
        </a>
    </div>
}