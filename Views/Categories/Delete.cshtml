@model StationeryShop.Models.Category

@{
    ViewData["Title"] = "Удалить категорию";
}

<h2>Удалить категорию</h2>

<h4>Вы уверены, что хотите удалить эту категорию?</h4>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-4">Название:</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Описание:</dt>
        <dd class="col-sm-8">@Model.Description</dd>

        <dt class="col-sm-4">Количество товаров:</dt>
        <dd class="col-sm-8">@Model.Products?.Count</dd>
    </dl>

    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="alert alert-warning">
            <strong>Внимание!</strong> В этой категории есть товары. При удалении категории все товары в ней также будут удалены.
        </div>
    }
</div>

<form asp-action="Delete" asp-route-id="@Model.CategoryID" method="post">
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>