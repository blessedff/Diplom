@model StationeryShop.Models.Category

@{
    ViewData["Title"] = "Информация о категории";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<h2>Информация о категории</h2>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Название:</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Описание:</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Количество товаров:</dt>
        <dd class="col-sm-9">@Model.Products?.Count</dd>
    </dl>

    @if (Model.Products != null && Model.Products.Any())
    {
        <h5 class="mt-4">Товары в этой категории:</h5>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Цена</th>
                        <th>Количество</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>@product.Name</td>
                            <td>@product.Price.ToString("0.00") byn</td>
                            <td>@product.StockQuantity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info mt-3">
            В этой категории пока нет товаров
        </div>
    }
</div>

<p class="mt-3">
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.CategoryID" class="btn btn-warning">Редактировать</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</p>