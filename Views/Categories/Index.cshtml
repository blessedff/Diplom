@model IEnumerable<StationeryShop.Models.Category>

@{
    ViewData["Title"] = "Категории товаров";
    bool isAdmin = ViewBag.IsAdmin;
}

<style>
    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
        text-align: center;
        width: 100%;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    .admin-notice {
        background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
        border-radius: 20px;
        padding: 15px 25px;
        margin-bottom: 30px;
        color: white;
        text-align: center;
    }

    .category-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background: white;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        cursor: pointer;
    }

        .category-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(44, 90, 160, 0.12);
        }

        .category-card .card-body {
            padding: 30px 20px;
        }

    .category-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        transition: all 0.3s ease;
    }

    .category-card:hover .category-icon {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
    }

    .category-icon i {
        font-size: 2rem;
        color: white;
    }

    .category-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 10px;
    }

    .category-description {
        font-size: 0.85rem;
        color: #6c757d;
        line-height: 1.5;
        margin-bottom: 15px;
    }

    .product-count {
        background: #f8f9fa;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #2c5aa0;
        display: inline-block;
    }

    .empty-categories {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }

        .empty-categories i {
            font-size: 5rem;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .empty-categories h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 10px;
        }

    .btn-add {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
        }

    .modal-content {
        border: none;
        border-radius: 24px;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .category-card {
        animation: fadeInUp 0.4s ease-out;
    }
</style>

<h2 class="page-title">
    <i class="bi bi-tags me-2"></i> Категории товаров
</h2>

@if (isAdmin)
{
    <div class="admin-notice">
        <i class="bi bi-shield-lock-fill me-2"></i>
        <strong>Режим администратора</strong>
        <br>
        <small>
            Управление категориями доступно в
            <a asp-controller="Admin" asp-action="Categories" class="text-white fw-bold text-decoration-underline">
                <i class="bi bi-speedometer2 me-1"></i> Панели администратора
            </a>
        </small>
    </div>
}

<div class="row g-4">
    @foreach (var category in Model)
    {
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="card category-card"
                 data-bs-toggle="modal"
                 data-bs-target="#categoryModal"
                 data-category-id="@category.CategoryID">
                <div class="card-body text-center">
                    <div class="category-icon mx-auto">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h5 class="category-title">@category.Name</h5>
                    <p class="category-description">
                        @if (!string.IsNullOrEmpty(category.Description) && category.Description.Length > 80)
                        {
                            @category.Description.Substring(0, 80)
                    
                            <text>...</text>
                        }
                        else
                        {
                            @category.Description
                        }
                    </p>
                    <div class="product-count">
                        <i class="bi bi-box-seam me-1"></i> @category.Products.Count товаров
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="empty-categories">
        <i class="bi bi-tags"></i>
        <h3>Категории отсутствуют</h3>
        <p class="text-muted">На данный момент в каталоге нет категорий</p>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-add text-white mt-2">
                <i class="bi bi-plus-circle me-2"></i> Добавить первую категорию
            </a>
        }
    </div>
}

<!-- Модальное окно для категории -->
<div class="modal fade" id="categoryModal" tabindex="-1" aria-labelledby="categoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body p-0" id="categoryModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Загрузка...</span>
                    </div>
                    <p class="mt-2 text-muted">Загрузка информации...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const categoryModal = document.getElementById('categoryModal');
            if (categoryModal) {
                categoryModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const categoryId = button.getAttribute('data-category-id');
                    const modalBody = document.getElementById('categoryModalBody');

                    modalBody.innerHTML = `
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Загрузка...</span>
                            </div>
                            <p class="mt-2 text-muted">Загрузка информации...</p>
                        </div>
                    `;

                    fetch(`/Categories/DetailsModal/${categoryId}`)
                        .then(response => response.text())
                        .then(html => {
                            modalBody.innerHTML = html;
                        })
                        .catch(error => {
                            modalBody.innerHTML = `
                                <div class="alert alert-danger m-4">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    Ошибка при загрузке информации о категории
                                </div>
                            `;
                        });
                });
            }
        });
    </script>
}