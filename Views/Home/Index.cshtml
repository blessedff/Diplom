@{
    ViewData["Title"] = "Главная страница";
}
@model List<StationeryShop.Models.Review>

<!-- Подключаем Swiper CSS и JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<style>
    /* Современные стили в стиле админ-панели */
    .hero-section {
        background: linear-gradient(135deg, #1a1a2e 0%, #2c5aa0 100%);
        border-radius: 30px;
        position: relative;
        overflow: hidden;
    }

        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.05)" fill-opacity="1" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
            background-size: cover;
            opacity: 0.15;
        }

        .hero-section .container {
            position: relative;
            z-index: 1;
        }

    .btn-hero {
        background: linear-gradient(135deg, #3a7bd5, #00d2ff);
        color: white;
        padding: 14px 40px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-hero:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(58, 123, 213, 0.4);
            color: white;
        }

    /* Единый стиль заголовков секций */
    .section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 0;
    }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -12px;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    .section-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-top: 1rem;
        margin-bottom: 0;
    }

    /* Карточки преимуществ */
    .feature-card {
        background: white;
        border-radius: 24px;
        padding: 35px 25px;
        text-align: center;
        transition: all 0.3s ease;
        height: 100%;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
    }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(44, 90, 160, 0.1);
            border-color: rgba(58, 123, 213, 0.2);
        }

    .feature-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #2c5aa0 0%, #3a7bd5 100%);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
    }

        .feature-icon i {
            font-size: 38px;
            color: white;
        }

    .feature-card h5 {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: #1a1a2e;
    }

    .feature-card p {
        color: #6c757d;
        line-height: 1.6;
    }

    /* Отзывы - карусель */
    .review-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        height: 100%;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 25px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid #f0f0f0;
    }

    .review-avatar {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .review-avatar i {
            font-size: 1.5rem;
            color: white;
        }

    .review-text {
        font-style: italic;
        color: #4a5568;
        line-height: 1.5;
        margin: 15px 0;
    }

    .review-date {
        font-size: 0.7rem;
        color: #6c757d;
    }

    .stars {
        font-size: 0.75rem;
        letter-spacing: 2px;
    }

    .admin-response {
        background: #f8fafc;
        border-radius: 16px;
        padding: 12px;
        margin-top: 12px;
        border-left: 3px solid #2c5aa0;
    }

        .admin-response small {
            font-size: 0.75rem;
        }

    /* Карусель */
    .reviews-carousel-container {
        position: relative;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .reviews-carousel {
        overflow: hidden;
        flex: 1;
        border-radius: 20px;
    }

    .carousel-track {
        display: flex;
        transition: transform 0.5s ease-in-out;
        gap: 25px;
    }

    .carousel-slide {
        flex: 0 0 calc(33.333% - 17px);
        min-width: calc(33.333% - 17px);
    }

    .carousel-btn {
        width: 45px;
        height: 45px;
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .carousel-btn:hover {
            background: #2c5aa0;
            color: white;
            border-color: #2c5aa0;
            transform: scale(1.05);
        }

        .carousel-btn i {
            font-size: 1.2rem;
            font-weight: bold;
        }

    /* Пункт выдачи */
    .pickup-address, .pickup-hours {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        margin-bottom: 25px;
        padding: 12px;
        background: #f8f9fa;
        border-radius: 16px;
    }

        .pickup-address i, .pickup-hours i {
            font-size: 1.5rem;
            min-width: 35px;
            margin-top: 3px;
        }

        .pickup-address strong, .pickup-hours strong {
            display: block;
            margin-bottom: 5px;
            font-size: 0.9rem;
        }

    .pickup-features {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 25px;
    }

        .pickup-features span {
            font-size: 0.8rem;
            color: #4a5568;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .pickup-features span i {
                font-size: 0.75rem;
                color: #28a745;
            }

    .pickup-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        padding: 10px 24px;
        border-radius: 30px;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

        .pickup-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
            color: white;
        }

    .pickup-map {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        border: 1px solid #e9ecef;
    }

    /* Адаптивность */
    @@media (max-width: 1024px) {
        .carousel-slide

    {
        flex: 0 0 calc(50% - 13px);
        min-width: calc(50% - 13px);
    }

    }

    @@media (max-width: 768px) {
        .carousel-slide

    {
        flex: 0 0 100%;
        min-width: 100%;
    }

    .carousel-btn {
        width: 35px;
        height: 35px;
    }

    .section-title {
        font-size: 1.5rem;
    }

    .pickup-address, .pickup-hours {
        padding: 10px;
    }

    .pickup-map iframe {
        height: 220px;
    }

    }

    /* Анимации */
    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .animate {
        animation: fadeInUp 0.6s ease-out;
    }
</style>

<!-- Hero секция -->
<div class="hero-section text-center py-5 mb-5 animate">
    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3 text-white">Канцелярский Магазин</h1>
        <p class="lead mb-4 text-white-50">Качественные канцтовары для офиса, школы и творчества</p>
        <a class="btn btn-hero btn-lg px-5" asp-controller="Products" asp-action="Index">
            <i class="bi bi-arrow-right me-2"></i>В каталог
        </a>
    </div>
</div>

<!-- Преимущества -->
<div class="container mb-5">
    <div class="section-header">
        <h2 class="section-title">Почему выбирают нас</h2>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon mx-auto">
                    <i class="bi bi-truck"></i>
                </div>
                <h5>Быстрая доставка</h5>
                <p>Доставка по городу в течение 24 часов после оформления заказа</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon mx-auto">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h5>Гарантия качества</h5>
                <p>Все товары сертифицированы и проходят строгий контроль</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon mx-auto">
                    <i class="bi bi-headset"></i>
                </div>
                <h5>Поддержка 24/7</h5>
                <p>Всегда готовы помочь с выбором и ответить на вопросы</p>
            </div>
        </div>
    </div>
</div>

<!-- Отзывы -->
<div class="container mb-5">
    <div class="section-header">
        <h2 class="section-title">Отзывы о нашем магазине</h2>
        <p class="section-subtitle">Что говорят наши покупатели</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="reviews-carousel-container">
            <button class="carousel-btn prev-btn" id="prevReviewBtn">
                <i class="bi bi-chevron-left"></i>
            </button>

            <div class="reviews-carousel" id="reviewsCarousel">
                <div class="carousel-track" id="carouselTrack">
                    @foreach (var review in Model)
                    {
                        <div class="carousel-slide">
                            <div class="review-card">
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    <div class="review-avatar">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-bold">@(review.Customer?.FullName ?? "Покупатель")</h6>
                                        <div class="stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= review.Rating)
                                                {
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-star text-muted"></i>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                                <p class="review-text">“@(review.Comment.Length > 200 ? review.Comment.Substring(0, 200) + "..." : review.Comment)”</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="review-date"><i class="bi bi-calendar3 me-1"></i> @review.CreatedAt.ToString("dd.MM.yyyy")</span>
                                    @if (!string.IsNullOrEmpty(review.AdminResponse))
                                    {
                                        <span class="badge bg-info" title="Ответ администратора">
                                            <i class="bi bi-chat-dots"></i> Ответ
                                        </span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(review.AdminResponse))
                                {
                                    <div class="admin-response">
                                        <small class="text-primary fw-bold"><i class="bi bi-reply-fill me-1"></i> Администратор:</small>
                                        <small class="text-muted d-block mt-1">@review.AdminResponse</small>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <button class="carousel-btn next-btn" id="nextReviewBtn">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Reviews" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">
                Все отзывы <i class="bi bi-arrow-right ms-1"></i>
            </a>
            <a asp-controller="Reviews" asp-action="Create" class="btn btn-primary rounded-pill px-4 ms-2">
                <i class="bi bi-pencil-square me-1"></i> Оставить отзыв
            </a>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-dots fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Пока нет отзывов</h5>
            <p class="text-muted">Будьте первым, кто поделится впечатлениями о нашем магазине!</p>
            <a asp-controller="Reviews" asp-action="Create" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-pencil-square me-1"></i> Оставить отзыв
            </a>
        </div>
    }
</div>

<!-- Пункт выдачи заказов -->
<div class="container mb-5">
    <div class="section-header">
        <h2 class="section-title">Пункт выдачи заказов</h2>
    </div>

    <div class="row align-items-center g-4">
        <div class="col-lg-5">
            <div class="pickup-info">
                <div class="pickup-address">
                    <i class="bi bi-geo-alt-fill text-primary"></i>
                    <div>
                        <strong>Адрес:</strong><br>
                        г. Гомель, ул. М.Г. Ефремова, 63А
                    </div>
                </div>

                <div class="pickup-hours">
                    <i class="bi bi-clock-fill text-primary"></i>
                    <div>
                        <strong>Режим работы:</strong><br>
                        Пн-Пт: 9:00 - 20:00<br>
                        Сб-Вс: 10:00 - 18:00
                    </div>
                </div>

                <div class="pickup-features">
                    <span><i class="bi bi-check-circle-fill"></i> Осмотр товара</span>
                    <span><i class="bi bi-check-circle-fill"></i> Оплата при получении</span>
                    <span><i class="bi bi-check-circle-fill"></i> Хранение 7 дней</span>
                </div>
            </div>
        </div>
        <div class="col-lg-7">
            <div class="pickup-map">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d751.7670135307951!2d30.96730473188399!3d52.461441773883855!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x46d46962f846fbaf%3A0xfd18d621a8e621ce!2zRWZyZW1vdmEgNjMsINCT0L7QvNC10LvRjCwg0JPQvtC80LXQu9GM0YHQutCw0Y8g0L7QsdC70LDRgdGC0YwgMjQ2MDM1!5e1!3m2!1sru!2sby!4v1776771407458!5m2!1sru!2sby"
                        width="100%"
                        height="320"
                        frameborder="0"
                        style="border:0; border-radius: 20px;"
                        allowfullscreen=""
                        loading="lazy">
                </iframe>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const track = document.getElementById('carouselTrack');
        const prevBtn = document.getElementById('prevReviewBtn');
        const nextBtn = document.getElementById('nextReviewBtn');

        if (!track || !prevBtn || !nextBtn) return;

        const slides = track.querySelectorAll('.carousel-slide');
        const totalSlides = slides.length;
        let currentIndex = 0;

        function getSlidesPerView() {
            if (window.innerWidth >= 1024) return 3;
            if (window.innerWidth >= 768) return 2;
            return 1;
        }

        function updateCarousel() {
            const slideWidth = slides[0]?.offsetWidth + 25;
            if (slideWidth) {
                track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
            }

            const slidesPerView = getSlidesPerView();
            prevBtn.disabled = currentIndex === 0;
            nextBtn.disabled = currentIndex >= totalSlides - slidesPerView;

            prevBtn.style.opacity = currentIndex === 0 ? '0.5' : '1';
            nextBtn.style.opacity = currentIndex >= totalSlides - slidesPerView ? '0.5' : '1';
            prevBtn.style.cursor = currentIndex === 0 ? 'not-allowed' : 'pointer';
            nextBtn.style.cursor = currentIndex >= totalSlides - slidesPerView ? 'not-allowed' : 'pointer';
        }

        prevBtn.addEventListener('click', function() {
            if (currentIndex > 0) {
                currentIndex--;
                updateCarousel();
            }
        });

        nextBtn.addEventListener('click', function() {
            const slidesPerView = getSlidesPerView();
            if (currentIndex < totalSlides - slidesPerView) {
                currentIndex++;
                updateCarousel();
            }
        });

        let resizeTimeout;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimeout);
            resizeTimeout = setTimeout(() => {
                currentIndex = 0;
                updateCarousel();
            }, 200);
        });

        setTimeout(updateCarousel, 100);
    });
</script>