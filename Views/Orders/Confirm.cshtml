@model StationeryShop.Models.Order

@{
    ViewData["Title"] = "Заказ подтвержден";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .confirm-container {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #28a745, #20c997);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }

        .success-icon i {
            font-size: 3rem;
            color: white;
        }

    .order-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #28a745;
        margin-bottom: 15px;
    }

    .order-number {
        font-size: 1.2rem;
        color: #4a5568;
        margin-bottom: 30px;
    }

        .order-number strong {
            font-size: 1.4rem;
            color: #2c5aa0;
        }

    .info-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-top: 20px;
    }

        .info-card .card-header {
            background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
            color: white;
            padding: 15px 25px;
            border: none;
        }

            .info-card .card-header h5 {
                margin: 0;
                font-weight: 600;
            }

        .info-card .card-body {
            padding: 25px;
        }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #e9ecef;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        font-weight: 600;
        color: #4a5568;
    }

    .info-value {
        color: #2d3748;
    }

    .status-badge {
        background: linear-gradient(135deg, #17a2b8, #0dcaf0);
        padding: 5px 15px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        color: white;
    }

    .total-amount {
        font-size: 1.3rem;
        font-weight: 700;
        color: #28a745;
    }

    .items-table {
        border-radius: 16px;
        overflow: hidden;
        margin-top: 15px;
    }

        .items-table thead th {
            background: #f8f9fa;
            font-weight: 600;
            padding: 12px;
            border-bottom: 2px solid #e9ecef;
        }

        .items-table tbody td {
            padding: 10px 12px;
            vertical-align: middle;
            border-bottom: 1px solid #e9ecef;
        }

        .items-table tfoot td {
            background: #f8f9fa;
            font-weight: 600;
            padding: 12px;
        }

    .btn-continue {
        background: #6c757d;
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
    }

        .btn-continue:hover {
            transform: translateY(-2px);
            background: #5a6268;
        }

    .btn-orders {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
    }

        .btn-orders:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
        }

    @@keyframes bounceIn {
        0% {
            opacity: 0;
            transform: scale(0.3);
        }

        50% {
            opacity: 1;
            transform: scale(1.05);
        }

        70% {
            transform: scale(0.9);
        }

        100% {
            transform: scale(1);
        }
    }

    .success-icon {
        animation: bounceIn 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .confirm-container {
        animation: fadeInUp 0.5s ease-out;
    }
</style>

<div class="confirm-container">
    <!-- Иконка успеха -->
    <div class="text-center">
        <div class="success-icon">
            <i class="bi bi-check-lg"></i>
        </div>

        <h1 class="order-title">Заказ успешно оформлен!</h1>
        <p class="order-number">
            Номер вашего заказа: <strong>#@Model.OrderID</strong>
        </p>
    </div>

    <!-- Информация о заказе -->
    <div class="info-card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-info-circle me-2"></i> Информация о заказе
            </h5>
        </div>
        <div class="card-body">
            <div class="info-row">
                <span class="info-label"><i class="bi bi-calendar3 me-2"></i> Дата заказа</span>
                <span class="info-value">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
            <div class="info-row">
                <span class="info-label"><i class="bi bi-geo-alt me-2"></i> Адрес доставки</span>
                <span class="info-value">@Model.ShippingAddress</span>
            </div>
            <div class="info-row">
                <span class="info-label"><i class="bi bi-tag me-2"></i> Статус</span>
                <span class="info-value">
                    <span class="status-badge">
                        <i class="bi bi-clock-history me-1"></i> @Model.Status
                    </span>
                </span>
            </div>
            <div class="info-row">
                <span class="info-label"><i class="bi bi-currency-dollar me-2"></i> Общая сумма</span>
                <span class="total-amount">@Model.TotalAmount.ToString("0.00") BYN</span>
            </div>

            @if (isAdmin && Model.Customer != null)
            {
                <div class="info-row">
                    <span class="info-label"><i class="bi bi-person me-2"></i> Клиент</span>
                    <span class="info-value">@Model.Customer.FullName</span>
                </div>
            }
        </div>
    </div>

    <!-- Состав заказа -->
    <div class="info-card">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-box-seam me-2"></i> Состав заказа
            </h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table items-table">
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th class="text-center">Количество</th>
                            <th class="text-end">Цена</th>
                            <th class="text-end">Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>
                                    >
                                    <i class="bi bi-box me-2 text-muted"></i> @item.Product?.Name
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary rounded-pill">@item.Quantity шт.</span>
                                </td>
                                <td class="text-end">@item.UnitPrice.ToString("0.00") BYN</td>
                                <td class="text-end fw-bold text-primary">@((item.Quantity * item.UnitPrice).ToString("0.00")) BYN</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end"><strong>Итого:</strong></td>
                            <td class="text-end"><strong class="total-amount">@Model.TotalAmount.ToString("0.00") BYN</strong></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Кнопки действий -->
    <div class="d-flex justify-content-between mt-4 flex-wrap gap-3">
        <a asp-controller="Products" asp-action="Index" class="btn btn-continue text-white">
            <i class="bi bi-bag me-2"></i> Продолжить покупки
        </a>
        <a asp-action="Index" class="btn btn-orders text-white">
            <i class="bi bi-list-ul me-2"></i> Перейти к списку заказов
        </a>
    </div>
</div>