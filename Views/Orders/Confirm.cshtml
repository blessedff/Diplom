@model StationeryShop.Models.Order

@{
    ViewData["Title"] = "Заказ подтвержден";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<div class="text-center py-4">
    <div class="mb-4">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
    </div>
    
    <h1 class="text-success mb-3">Заказ успешно оформлен!</h1>
    <p class="lead mb-4">Номер вашего заказа: <strong>#@Model.OrderID</strong></p>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h5 class="card-title mb-0">Информация о заказе</h5>
    </div>
    <div class="card-body">
        @if (isAdmin)
        {
            <p><strong>Клиент:</strong> @Model.Customer?.FullName</p>
        }
        
        <p><strong>Дата заказа:</strong> @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</p>
        <p><strong>Адрес доставки:</strong> @Model.ShippingAddress</p>
        <p><strong>Статус:</strong> <span class="badge bg-info">@Model.Status</span></p>
        <p><strong>Общая сумма:</strong> <span class="fw-bold text-success">@Model.TotalAmount.ToString("0.00") byn</span></p>

        <h6 class="mt-4">Состав заказа:</h6>
        <div class="table-responsive">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th>Количество</th>
                        <th>Цена</th>
                        <th>Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("0.00") byn</td>
                            <td>@((item.Quantity * item.UnitPrice).ToString("0.00")) byn</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-active">
                        <td colspan="3" class="text-end"><strong>Итого:</strong></td>
                        <td><strong>@Model.TotalAmount.ToString("0.00") byn</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mt-4">
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-bag"></i> Продолжить покупки
    </a>
    <a asp-action="Index" class="btn btn-primary">
        <i class="bi bi-list-ul"></i> Перейти к списку заказов
    </a>
</div>