@model StationeryShop.Models.Order

@{
    ViewData["Title"] = "Заказ подтвержден";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .confirm-container {
        max-width: 900px;
        margin: 0 auto;
        animation: fadeInUp 0.4s ease-out;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

    .page-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 2px;
    }

    /* Единая карточка */
    .order-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
    }

    /* Успешная иконка */
    .success-header {
        background: linear-gradient(135deg, #28a745, #20c997);
        padding: 25px;
        text-align: center;
    }

    .success-icon {
        width: 70px;
        height: 70px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        animation: bounceIn 0.6s ease-out;
    }

    .success-icon i {
        font-size: 2.5rem;
        color: #28a745;
    }

    .order-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        margin-bottom: 5px;
    }

    .order-number {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.9);
    }

    .order-number strong {
        font-size: 1rem;
        color: white;
    }

    /* Информационная секция */
    .info-section {
        padding: 25px;
        border-bottom: 1px solid #e9ecef;
    }

    .info-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .info-item {
        flex: 1;
        min-width: 180px;
    }

    .info-item i {
        font-size: 1.2rem;
        color: #2c5aa0;
        margin-right: 8px;
    }

    .info-item .label {
        font-size: 0.75rem;
        color: #6c757d;
        display: block;
        margin-bottom: 4px;
    }

    .info-item .value {
        font-size: 0.95rem;
        font-weight: 500;
        color: #2d3748;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #cfe2ff;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #084298;
    }

    .total-amount {
        font-size: 1.1rem;
        font-weight: 700;
        color: #28a745;
    }

    /* Таблица товаров */
    .items-section {
        padding: 0 25px 25px 25px;
    }

    .items-table {
        width: 100%;
        border-collapse: collapse;
    }

    .items-table th {
        text-align: left;
        padding: 12px 8px;
        border-bottom: 1px solid #e9ecef;
        font-size: 0.8rem;
        font-weight: 600;
        color: #6c757d;
    }

    .items-table th.text-end {
        text-align: right;
    }

    .items-table th.text-center {
        text-align: center;
    }

    .items-table td {
        padding: 12px 8px;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
    }

    .items-table td.text-end {
        text-align: right;
    }

    .items-table td.text-center {
        text-align: center;
    }

    .product-name {
        font-weight: 600;
        color: #1a1a2e;
    }

    .product-quantity .badge {
        background: #f0f2f5;
        color: #4a5568;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .product-price {
        color: #4a5568;
    }

    .product-total {
        font-weight: 700;
        color: #2c5aa0;
    }

    .total-row td {
        border-top: 1px solid #e9ecef;
        border-bottom: none;
        padding-top: 15px;
    }

    .total-label {
        font-weight: 700;
        font-size: 1rem;
    }

    .total-value {
        font-weight: 800;
        font-size: 1.2rem;
        color: #28a745;
    }

    /* Кнопки */
    .action-buttons {
        display: flex;
        justify-content: space-between;
        gap: 15px;
        padding: 20px 25px 25px 25px;
        border-top: 1px solid #e9ecef;
        flex-wrap: wrap;
    }

    .btn-continue {
        background: #6c757d;
        border: none;
        border-radius: 40px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: white;
    }

    .btn-continue:hover {
        background: #5a6268;
        transform: translateY(-2px);
        color: white;
    }

    .btn-orders {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border: none;
        border-radius: 40px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: white;
    }

    .btn-orders:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
        color: white;
    }

    /* Анимации */
    @@keyframes bounceIn {
        0% {
            opacity: 0;
            transform: scale(0.3);
        }
        50% {
            opacity: 1;
            transform: scale(1.05);
        }
        100% {
            transform: scale(1);
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .info-grid {
            flex-direction: column;
            gap: 12px;
        }
        .info-item {
            width: 100%;
        }
        .action-buttons {
            flex-direction: column;
        }
        .action-buttons a {
            width: 100%;
            justify-content: center;
        }
        .items-table th, 
        .items-table td {
            padding: 8px 5px;
            font-size: 0.8rem;
        }
    }
</style>

<div class="confirm-container">
    <h2 class="page-title"><i class="bi bi-check2-circle me-2"></i> Подтверждение заказа</h2>

    <!-- Единая карточка -->
    <div class="order-card">
        <!-- Шапка с успехом -->
        <div class="success-header">
            <div class="success-icon">
                <i class="bi bi-check-lg"></i>
            </div>
            <div class="order-title">Заказ успешно оформлен!</div>
            <div class="order-number">Номер заказа: <strong>#@Model.OrderID</strong></div>
        </div>

        <!-- Информация о заказе -->
        <div class="info-section">
            <div class="info-grid">
                <div class="info-item">
                    <i class="bi bi-calendar3"></i>
                    <span class="label">Дата заказа</span>
                    <div class="value">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-geo-alt"></i>
                    <span class="label">Пункт выдачи</span>
                    <div class="value">@Model.ShippingAddress</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-tag"></i>
                    <span class="label">Статус</span>
                    <div class="value">
                        <span class="status-badge">
                            <i class="bi bi-clock-history"></i> @Model.Status
                        </span>
                    </div>
                </div>
                <div class="info-item">
                    <i class="bi bi-currency-dollar"></i>
                    <span class="label">Общая сумма</span>
                    <div class="value total-amount">@Model.TotalAmount.ToString("0.00") BYN</div>
                </div>
                @if (isAdmin && Model.Customer != null)
                {
                    <div class="info-item">
                        <i class="bi bi-person"></i>
                        <span class="label">Клиент</span>
                        <div class="value">@Model.Customer.FullName</div>
                    </div>
                    <div class="info-item">
                        <i class="bi bi-envelope"></i>
                        <span class="label">Email</span>
                        <div class="value">@Model.Customer.Email</div>
                    </div>
                }
            </div>
        </div>

        <!-- Состав заказа -->
        <!-- Состав заказа -->
        <div class="items-section">
            <div class="table-responsive">
                <table class="items-table">
                    <thead>
                        <tr>
                            <th>Товар</th>
                            <th class="text-center">Количество</th>
                            <th class="text-end">Цена</th>
                            <th class="text-end">Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="product-name">
                                    <i class="bi bi-box-seam me-2 text-muted"></i> @item.Product?.Name
                                </td>
                                <td class="text-center product-quantity">
                                    <span class="badge">@item.Quantity шт.</span>
                                </td>
                                <td class="text-end product-price">@item.UnitPrice.ToString("0.00") BYN</td>
                                <td class="text-end product-total">@((item.Quantity * item.UnitPrice).ToString("0.00")) BYN</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end total-label">ИТОГО:</td>
                            <td class="text-end total-value">@Model.TotalAmount.ToString("0.00") BYN</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

        <!-- Кнопки действий -->
        <div class="action-buttons">
            <a asp-controller="Products" asp-action="Index" class="btn-continue">
                <i class="bi bi-bag"></i> Продолжить покупки
            </a>
            <a asp-action="Index" class="btn-orders">
                <i class="bi bi-list-ul"></i> Перейти к списку заказов
            </a>
        </div>
    </div>
</div>