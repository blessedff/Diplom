@model StationeryShop.Models.Order

@{
    ViewData["Title"] = "Детали заказа";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }
    
    .page-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 2px;
    }
    
    .order-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
    }
    
    .order-card .card-header {
        background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
        color: white;
        padding: 15px 25px;
        border: none;
    }
    
    .order-card .card-header h5 {
        margin: 0;
        font-weight: 600;
    }
    
    .order-card .card-body {
        padding: 25px;
    }
    
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 25px;
    }
    
    .info-group {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px 20px;
    }
    
    .info-group p {
        margin-bottom: 8px;
    }
    
    .info-group p:last-child {
        margin-bottom: 0;
    }
    
    .info-label {
        font-weight: 600;
        color: #4a5568;
        margin-right: 8px;
    }
    
    .info-value {
        color: #2d3748;
    }
    
    .order-number {
        font-size: 1.2rem;
        font-weight: 700;
        color: #2c5aa0;
    }
    
    .status-badge {
        padding: 5px 15px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }
    .status-completed { background: #d4edda; color: #155724; }
    .status-cancelled { background: #f8d7da; color: #721c24; }
    .status-ready { background: #fff3cd; color: #856404; }
    .status-default { background: #cfe2ff; color: #084298; }
    
    .total-amount {
        font-size: 1.2rem;
        font-weight: 700;
        color: #28a745;
    }
    
    .items-table {
        border-radius: 16px;
        overflow: hidden;
        margin-top: 15px;
    }
    
    .items-table thead th {
        background: #f8f9fa;
        font-weight: 600;
        padding: 12px 15px;
        border-bottom: 2px solid #e9ecef;
    }
    
    .items-table tbody td {
        padding: 12px 15px;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
    }
    
    .product-image {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 10px;
        margin-right: 12px;
    }
    
    .product-name {
        font-weight: 600;
        color: #1a1a2e;
    }
    
    .product-description {
        font-size: 0.75rem;
        color: #6c757d;
    }
    
    .btn-back {
        background: #6c757d;
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
    }
    
    .btn-back:hover {
        transform: translateY(-2px);
        background: #5a6268;
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .order-card {
        animation: fadeInUp 0.4s ease-out;
    }
    
</style>

<h2 class="page-title">
    <i class="bi bi-receipt me-2"></i> Детали заказа <span class="order-number">#@Model.OrderID</span>
</h2>

<div class="order-card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-info-circle me-2"></i> Информация о заказе
        </h5>
    </div>
    <div class="card-body">
        <!-- Информационные блоки -->
        <div class="info-grid">
            <div class="info-group">
                <p>
                    <span class="info-label"><i class="bi bi-upc-scan me-1"></i> Номер заказа:</span>
                    <span class="order-number">#@Model.OrderID</span>
                </p>
                <p>
                    <span class="info-label"><i class="bi bi-calendar3 me-1"></i> Дата заказа:</span>
                    <span class="info-value">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</span>
                </p>
                <p>
                    <span class="info-label"><i class="bi bi-tag me-1"></i> Статус:</span>
                    <span class="status-badge 
                        @(Model.Status == "Выполнен" ? "status-completed" :
                          Model.Status == "Отменен" ? "status-cancelled" :
                          Model.Status == "Готов к выдаче" ? "status-ready" : "status-default")">
                        <i class="bi 
                            @(Model.Status == "Выполнен" ? "bi-check-circle" :
                              Model.Status == "Отменен" ? "bi-x-circle" :
                              Model.Status == "Готов к выдаче" ? "bi-clock-history" : "bi-hourglass-split") me-1"></i>
                        @Model.Status
                    </span>
                </p>
            </div>
            
            <div class="info-group">
                <p>
                    <span class="info-label"><i class="bi bi-geo-alt me-1"></i> Адрес доставки:</span>
                    <span class="info-value">@Model.ShippingAddress</span>
                </p>
                <p>
                    <span class="info-label"><i class="bi bi-currency-dollar me-1"></i> Общая сумма:</span>
                    <span class="total-amount">@Model.TotalAmount.ToString("0.00") BYN</span>
                </p>
            </div>
        </div>

        <!-- Информация о клиенте (только для админа) -->
        @if (isAdmin && Model.Customer != null)
        {
            <div class="info-grid" style="margin-top: -10px;">
                <div class="info-group">
                    <p>
                        <span class="info-label"><i class="bi bi-person me-1"></i> Клиент:</span>
                        <span class="info-value">@Model.Customer.FullName</span>
                    </p>
                </div>
                <div class="info-group">
                    <p>
                        <span class="info-label"><i class="bi bi-envelope me-1"></i> Email:</span>
                        <span class="info-value">@Model.Customer.Email</span>
                    </p>
                    <p>
                        <span class="info-label"><i class="bi bi-telephone me-1"></i> Телефон:</span>
                        <span class="info-value">@Model.Customer.Phone</span>
                    </p>
                </div>
            </div>
        }

        <!-- Состав заказа -->
        <h6 class="mt-3 fw-bold">
            <i class="bi bi-box-seam me-2"></i> Состав заказа
        </h6>

        <div class="table-responsive">
            <table class="table items-table">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th class="text-end">Цена</th>
                        <th class="text-center">Количество</th>
                        <th class="text-end">Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    @if (item.Product?.PhotoBase64 != null)
                                    {
                                        <img src="data:image/png;base64,@item.Product.PhotoBase64"
                                             alt="@item.Product.Name"
                                             class="product-image">
                                    }
                                    else
                                    {
                                        <div class="product-image bg-light d-flex align-items-center justify-content-center rounded">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="product-name">@item.Product?.Name</div>
                                        @if (!string.IsNullOrEmpty(item.Product?.Description))
                                        {
                                            <div class="product-description">@(item.Product.Description.Length > 60 ? item.Product.Description.Substring(0, 60) + "..." : item.Product.Description)</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="text-end">@item.UnitPrice.ToString("0.00") BYN</td>
                            <td class="text-center">
                                <span class="badge bg-secondary rounded-pill">@item.Quantity шт.</span>
                            </td>
                            <td class="text-end fw-bold text-primary">@((item.Quantity * item.UnitPrice).ToString("0.00")) BYN</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background: #f8f9fa;">
                        <td colspan="3" class="text-end fw-bold">Итого:</td>
                        <td class="text-end fw-bold text-success fs-5">@Model.TotalAmount.ToString("0.00") BYN</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-back text-white">
        <i class="bi bi-arrow-left me-2"></i> Назад к списку заказов
    </a>
</div>