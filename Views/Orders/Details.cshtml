@model StationeryShop.Models.Order

@{
    ViewData["Title"] = "Детали заказа";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    /* Единая карточка */
    .order-details-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        animation: fadeInUp 0.4s ease-out;
    }

    /* Информационная секция */
    .info-section {
        padding: 25px;
        border-bottom: 1px solid #e9ecef;
    }

    .info-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .info-item {
        flex: 1;
        min-width: 200px;
    }

        .info-item i {
            font-size: 1.2rem;
            color: #2c5aa0;
            margin-right: 8px;
            width: 28px;
        }

        .info-item .label {
            font-size: 0.75rem;
            color: #6c757d;
            display: block;
            margin-bottom: 4px;
        }

        .info-item .value {
            font-size: 0.95rem;
            font-weight: 500;
            color: #2d3748;
        }

    .order-number-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #2c5aa0;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 14px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .status-completed {
        background: #d4edda;
        color: #155724;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #721c24;
    }

    .status-ready {
        background: #fff3cd;
        color: #856404;
    }

    .status-default {
        background: #cfe2ff;
        color: #084298;
    }

    .total-amount {
        font-size: 1.1rem;
        font-weight: 700;
        color: #28a745;
    }

    /* Таблица товаров */
    .items-section {
        padding: 0 25px 25px 25px;
    }

    .items-table {
        width: 100%;
        border-collapse: collapse;
    }

        .items-table th {
            text-align: left;
            padding: 12px 8px;
            border-bottom: 1px solid #e9ecef;
            font-size: 0.8rem;
            font-weight: 600;
            color: #6c757d;
        }

            .items-table th.text-end {
                text-align: right;
            }

            .items-table th.text-center {
                text-align: center;
            }

        .items-table td {
            padding: 12px 8px;
            border-bottom: 1px solid #e9ecef;
            vertical-align: middle;
        }

            .items-table td.text-end {
                text-align: right;
            }

            .items-table td.text-center {
                text-align: center;
            }

    .product-image {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 10px;
        margin-right: 12px;
    }

    .product-name {
        font-weight: 600;
        color: #1a1a2e;
    }

    .product-description {
        font-size: 0.7rem;
        color: #6c757d;
    }

    .product-quantity .badge {
        background: #f0f2f5;
        color: #4a5568;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .product-price {
        color: #4a5568;
    }

    .product-total {
        font-weight: 700;
        color: #2c5aa0;
    }

    .total-row td {
        border-top: 1px solid #e9ecef;
        border-bottom: none;
        padding-top: 15px;
    }

    .total-label {
        font-weight: 700;
        font-size: 1rem;
    }

    .total-value {
        font-weight: 800;
        font-size: 1.2rem;
        color: #28a745;
    }

    /* Кнопка назад */
    .btn-back {
        background: #6c757d;
        border: none;
        border-radius: 40px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: white;
        margin-top: 20px;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    /* Анимации */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .info-grid {
            flex-direction: column;
            gap: 12px;
        }

        .info-item {
            width: 100%;
        }

        .items-table th,
        .items-table td {
            padding: 8px 5px;
            font-size: 0.75rem;
        }
    }
</style>

<h2 class="page-title">
    <i class="bi bi-receipt me-2"></i> Детали заказа <span class="order-number-value">#@Model.OrderID</span>
</h2>

<div class="order-details-card">
    <!-- Информация о заказе -->
    <div class="info-section">
        <div class="info-grid">
            <div class="info-item">
                <i class="bi bi-upc-scan"></i>
                <span class="label">Номер заказа</span>
                <div class="value order-number-value">#@Model.OrderID</div>
            </div>
            <div class="info-item">
                <i class="bi bi-calendar3"></i>
                <span class="label">Дата заказа</span>
                <div class="value">@Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
            <div class="info-item">
                <i class="bi bi-tag"></i>
                <span class="label">Статус</span>
                <div class="value">
                    <span class="status-badge
                        @(Model.Status == "Выполнен" ? "status-completed" :
                                                    Model.Status == "Отменен" ? "status-cancelled" :
                                                    Model.Status == "Готов к выдаче" ? "status-ready" : "status-default")">
                        @if (Model.Status == "Выполнен")
                        {
                            <i class="bi bi-check-circle"></i>
                        }
                        else if (Model.Status == "Отменен")
                        {
                            <i class="bi bi-x-circle"></i>
                        }
                        else if (Model.Status == "Готов к выдаче")
                        {
                            <i class="bi bi-clock-history"></i>
                        }
                        else
                        {
                            <i class="bi bi-hourglass-split"></i>
                        }
                        @Model.Status
                    </span>
                </div>
            </div>
            <div class="info-item">
                <i class="bi bi-geo-alt"></i>
                <span class="label">Пункт выдачи</span>
                <div class="value">@Model.ShippingAddress</div>
            </div>
            <div class="info-item">
                <i class="bi bi-currency-dollar"></i>
                <span class="label">Общая сумма</span>
                <div class="value total-amount">@Model.TotalAmount.ToString("0.00") BYN</div>
            </div>
        </div>

        <!-- Информация о клиенте (только для админа) -->
        @if (isAdmin && Model.Customer != null)
        {
            <div class="info-grid" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #e9ecef;">
                <div class="info-item">
                    <i class="bi bi-person"></i>
                    <span class="label">Клиент</span>
                    <div class="value">@Model.Customer.FullName</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-envelope"></i>
                    <span class="label">Email</span>
                    <div class="value">@Model.Customer.Email</div>
                </div>
                <div class="info-item">
                    <i class="bi bi-telephone"></i>
                    <span class="label">Телефон</span>
                    <div class="value">@Model.Customer.Phone</div>
                </div>
            </div>
        }
    </div>

    <!-- Состав заказа -->
    <div class="items-section">
        <div class="table-responsive">
            <table class="items-table">
                <thead>
                    <tr>
                        <th>Товар</th>
                        <th class="text-center">Количество</th>
                        <th class="text-end">Цена</th>
                        <th class="text-end">Сумма</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td class="product-name">
                                <div class="d-flex align-items-center">
                                    @if (item.Product?.PhotoBase64 != null)
                                    {
                                        <img src="data:image/png;base64,@item.Product.PhotoBase64"
                                             alt="@item.Product.Name"
                                             class="product-image">
                                    }
                                    else
                                    {
                                        <div class="product-image bg-light d-flex align-items-center justify-content-center rounded">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div>
                                        <div class="product-name">@item.Product?.Name</div>
                                        @if (!string.IsNullOrEmpty(item.Product?.Description))
                                        {
                                            <div class="product-description">@(item.Product.Description.Length > 60 ? item.Product.Description.Substring(0, 60) + "..." : item.Product.Description)</div>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="text-center product-quantity">
                                <span class="badge">@item.Quantity шт.</span>
                            </td>
                            <td class="text-end product-price">@item.UnitPrice.ToString("0.00") BYN</td>
                            <td class="text-end product-total">@((item.Quantity * item.UnitPrice).ToString("0.00")) BYN</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="total-row">
                        <td colspan="3" class="text-end total-label">ИТОГО:</td>
                        <td class="text-end total-value">@Model.TotalAmount.ToString("0.00") BYN</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn-back">
        <i class="bi bi-arrow-left"></i> Назад к списку заказов
    </a>
</div>