@model IEnumerable<StationeryShop.Models.Order>

@{
    ViewData["Title"] = "Список заказов";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<h2 class="mb-4">Список заказов</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (Model != null && Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    @if (isAdmin)
                    {
                        <th>Клиент</th>
                    }
                    <th>Номер заказа</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        @if (isAdmin)
                        {
                            <td>@order.Customer?.FullName</td>
                        }
                        <td>#@order.OrderID</td>
                        <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@order.TotalAmount.ToString("0.00") byn</td>
                        <td>
                            @if (isAdmin)
                            {
                                <form asp-action="UpdateStatus" method="post" class="d-inline">
                                    <input type="hidden" name="orderId" value="@order.OrderID" />
                                    <select name="status" onchange="this.form.submit()" class="form-select form-select-sm">
                                        <option value="Принят" selected="@(order.Status == "Принят")">Принят</option>
                                        <option value="Сформирован" selected="@(order.Status == "Сформирован")">Сформирован</option>
                                        <option value="Готов к выдаче" selected="@(order.Status == "Готов к выдаче")">Готов к выдаче</option>
                                        <option value="Выполнен" selected="@(order.Status == "Выполнен")">Выполнен</option>
                                        <option value="Отменен" selected="@(order.Status == "Отменен")">Отменен</option>
                                    </select>
                                </form>
                            }
                            else
                            {
                                <span class="badge 
                                    @(order.Status == "Выполнен" ? "bg-success" :
                                      order.Status == "Отменен" ? "bg-danger" :
                                      order.Status == "Готов к выдаче" ? "bg-warning" : "bg-info")">
                                    @order.Status
                                </span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.OrderID" class="btn btn-sm btn-info">
                                <i class="bi bi-eye"></i> Детали
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-bag-x" style="font-size: 4rem; color: #6c757d;"></i>
        <h3 class="mt-3">Заказы отсутствуют</h3>
        <p class="text-muted">У вас пока нет оформленных заказов</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3">
            <i class="bi bi-bag"></i> Перейти к покупкам
        </a>
    </div>
}