@model IEnumerable<StationeryShop.Models.Order>

@{
    ViewData["Title"] = "Список заказов";
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    /* Карточки заказов */
    .orders-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 20px;
        animation: fadeInUp 0.4s ease-out;
    }

    .order-card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e9ecef;
        overflow: hidden;
        transition: all 0.3s ease;
        position: relative;
    }

        .order-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

    /* Шапка карточки */
    .order-card-header {
        background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
        padding: 15px 20px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-number {
        font-size: 1rem;
        font-weight: 700;
    }

    .order-date {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    /* Тело карточки */
    .order-card-body {
        padding: 20px;
    }

    .order-customer {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
        padding-bottom: 12px;
        border-bottom: 1px solid #e9ecef;
    }

        .order-customer i {
            font-size: 1.2rem;
            color: #2c5aa0;
            background: #e8f4fd;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

    .order-customer-info {
        flex: 1;
    }

    .order-customer-name {
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 2px;
    }

    .order-customer-email {
        font-size: 0.7rem;
        color: #6c757d;
    }

    .order-info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

    .order-info-label {
        font-size: 0.75rem;
        color: #6c757d;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .order-info-value {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .order-total {
        font-size: 1.2rem;
        font-weight: 800;
        color: #28a745;
    }

    /* Статус */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .status-completed {
        background: #d4edda;
        color: #155724;
    }

    .status-cancelled {
        background: #f8d7da;
        color: #721c24;
    }

    .status-ready {
        background: #fff3cd;
        color: #856404;
    }

    .status-default {
        background: #cfe2ff;
        color: #084298;
    }

    /* Кнопки действий */
    .order-actions {
        display: flex;
        gap: 10px;
        margin-top: 15px;
        padding-top: 15px;
        border-top: 1px solid #e9ecef;
    }

    .btn-details {
        flex: 1;
        background: #6c757d;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 15px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

        .btn-details:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .btn-receipt {
        flex: 1;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 15px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

        .btn-receipt:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
            color: white;
        }

    /* Пустая корзина */
    .empty-orders {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
        animation: fadeInUp 0.4s ease-out;
    }

        .empty-orders i {
            font-size: 5rem;
            color: #cbd5e1;
            margin-bottom: 20px;
        }

        .empty-orders h3 {
            font-size: 1.5rem;
            font-weight: 600;
            color: #1a1a2e;
            margin-bottom: 10px;
        }

    .btn-shop {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
        color: white;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-shop:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
            color: white;
        }

    /* Адаптивность */
    @@media (max-width: 768px) {
        .orders-grid {
            grid-template-columns: 1fr;
        }
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<h2 class="page-title">
    <i class="bi bi-list-ul me-2"></i> Список заказов
</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="orders-grid">
        @foreach (var order in Model.OrderByDescending(o => o.OrderDate))
        {
            <div class="order-card">
                <div class="order-card-header">
                    <div>
                        <div class="order-number">Заказ #@order.OrderID</div>
                        <div class="order-date">@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                    <div>
                        @{
                            string statusClass = "status-default";
                            if (order.Status == "Выполнен") statusClass = "status-completed";
                            else if (order.Status == "Отменен") statusClass = "status-cancelled";
                            else if (order.Status == "Готов к выдаче") statusClass = "status-ready";
                        }
                        <span class="status-badge @statusClass">
                            @if (order.Status == "Выполнен")
                            {
                                <i class="bi bi-check-circle"></i>
                            }
                            else if (order.Status == "Отменен")
                            {
                                <i class="bi bi-x-circle"></i>
                            }
                            else if (order.Status == "Готов к выдаче")
                            {
                                <i class="bi bi-clock-history"></i>
                            }
                            else
                            {
                                <i class="bi bi-hourglass-split"></i>
                            }
                            @order.Status
                        </span>
                    </div>
                </div>
                <div class="order-card-body">
                    <!-- Информация о клиенте (только для админа) -->
                    @if (isAdmin)
                    {
                        <div class="order-customer">
                            <i class="bi bi-person"></i>
                            <div class="order-customer-info">
                                <div class="order-customer-name">@(order.Customer?.FullName ?? "Клиент не указан")</div>
                                <div class="order-customer-email">@(order.Customer?.Email ?? "")</div>
                            </div>
                        </div>
                    }

                    <!-- Информация о заказе -->
                    <div class="order-info-row">
                        <span class="order-info-label"><i class="bi bi-credit-card"></i> Сумма</span>
                        <span class="order-info-value order-total">@order.TotalAmount.ToString("0.00") BYN</span>
                    </div>
                    <div class="order-info-row">
                        <span class="order-info-label"><i class="bi bi-truck"></i> Доставка</span>
                        <span class="order-info-value">Пункт выдачи</span>
                    </div>
                    <div class="order-info-row">
                        <span class="order-info-label"><i class="bi bi-box-seam"></i> Товаров</span>
                        <span class="order-info-value">@order.OrderItems.Sum(oi => oi.Quantity) шт.</span>
                    </div>

                    <!-- Кнопки действий -->
                    <div class="order-actions">
                        <a asp-action="Details" asp-route-id="@order.OrderID" class="btn-details">
                            <i class="bi bi-eye"></i> Детали
                        </a>
                        <a asp-action="ClientReceipt" asp-route-id="@order.OrderID" class="btn-receipt" target="_blank">
                            <i class="bi bi-receipt"></i> Чек
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-orders">
        <i class="bi bi-bag-x"></i>
        <h3>Заказы отсутствуют</h3>
        <p class="text-muted">У вас пока нет оформленных заказов</p>
        <a asp-controller="Products" asp-action="Index" class="btn-shop">
            <i class="bi bi-bag me-2"></i> Перейти к покупкам
        </a>
    </div>
}