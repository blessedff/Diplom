@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Редактирование товара";
}

@model StationeryShop.Models.Product

<style>
    .form-container {
        background: white;
        border-radius: 24px;
        padding: 30px;
        max-width: 800px;
        margin: 0 auto;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .page-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 4px;
            background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            border-radius: 2px;
        }

    .form-label {
        font-weight: 600;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        padding: 12px 15px;
        transition: all 0.2s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #2c5aa0;
            box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
            outline: none;
        }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .current-photo {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        margin: 15px 0;
    }

        .current-photo img {
            max-width: 150px;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .current-photo p {
            margin: 10px 0 0 0;
            color: #6c757d;
        }

    .btn-save {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        }

    .btn-back {
        background: #6c757d;
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            background: #5a6268;
        }

    .required-field::after {
        content: '*';
        color: #dc3545;
        margin-left: 4px;
    }

    .photo-section {
        border-top: 1px solid #e9ecef;
        padding-top: 20px;
        margin-top: 10px;
    }

    /* Стили для подсказок цен */
    .price-hints {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        margin: 20px 0;
        border-left: 4px solid #2c5aa0;
        display: none;
    }

        .price-hints h6 {
            font-size: 0.9rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: #1a1a2e;
        }

    .hint-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 0;
        border-bottom: 1px dashed #e9ecef;
    }

        .hint-row:last-child {
            border-bottom: none;
        }

    .hint-label {
        font-size: 0.8rem;
        color: #6c757d;
    }

    .hint-value {
        font-weight: 700;
        font-size: 0.9rem;
    }

        .hint-value.recommended {
            color: #2c5aa0;
        }

        .hint-value.breakeven {
            color: #fd7e14;
        }

        .hint-value.profit {
            color: #28a745;
        }

        .hint-value.warning {
            color: #dc3545;
        }

    .advice-text {
        margin-top: 10px;
        font-size: 0.75rem;
        padding: 8px;
        border-radius: 10px;
        background: #e8f4fd;
        color: #2c5aa0;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-container {
        animation: fadeInUp 0.4s ease-out;
    }
</style>

<div class="form-container">
    <h2 class="page-title">
        <i class="bi bi-pencil-square me-2"></i> Редактирование товара
    </h2>

    <form asp-action="Edit" enctype="multipart/form-data" method="post" id="productForm">
        <input type="hidden" asp-for="ProductID" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label required-field">Название товара</label>
            <input asp-for="Name" class="form-control" placeholder="Введите название товара" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Description" class="form-label">Описание</label>
            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Введите описание товара (необязательно)"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="PurchaseCost" class="form-label">Себестоимость (цена закупки)</label>
                <input asp-for="PurchaseCost" class="form-control" type="number" step="0.01" placeholder="0.00" id="PurchaseCost" />
                <span asp-validation-for="PurchaseCost" class="text-danger"></span>
                <small class="form-text text-muted">Цена, по которой вы закупаете товар у поставщика</small>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Price" class="form-label required-field">Цена продажи (BYN)</label>
                <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="0.00" id="SellingPrice" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
        </div>

        <!-- Блок с подсказками цен -->
        <div id="priceHints" class="price-hints">
            <h6><i class="bi bi-lightbulb me-2"></i> Подсказки по ценообразованию</h6>
            <div class="hint-row">
                <span class="hint-label">💰 Рекомендуемая цена (наценка 50%):</span>
                <span class="hint-value recommended" id="recommendedPrice">—</span>
            </div>
            <div class="hint-row">
                <span class="hint-label">⚠️ Минимальная цена (безубыток):</span>
                <span class="hint-value breakeven" id="breakEvenPrice">—</span>
            </div>
            <div class="hint-row">
                <span class="hint-label">📈 Прибыль с единицы:</span>
                <span class="hint-value profit" id="profitPerUnit">—</span>
            </div>
            <div class="hint-row">
                <span class="hint-label">📊 Ваша текущая цена:</span>
                <span class="hint-value" id="currentPriceStatus">—</span>
            </div>
            <div id="adviceText" class="advice-text">
                <i class="bi bi-info-circle me-1"></i>
                Введите себестоимость, чтобы получить рекомендации по цене
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="StockQuantity" class="form-label">Количество на складе</label>
            <input asp-for="StockQuantity" class="form-control" type="number" min="0" placeholder="0" />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CategoryID" class="form-label required-field">Категория</label>
            <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID">
                <option value="">-- Выберите категорию --</option>
            </select>
            <span asp-validation-for="CategoryID" class="text-danger"></span>
        </div>

        <!-- Текущее фото -->
        <div class="photo-section">
            <label class="form-label">Текущее фото</label>
            <div class="current-photo">
                @if (Model.PhotoBase64 != null)
                {
                    <img src="data:image/png;base64,@Model.PhotoBase64" alt="Фото товара" />
                    <p><i class="bi bi-image me-1"></i> Текущее фото товара</p>
                }
                else
                {
                    <i class="bi bi-image" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <p><i class="bi bi-info-circle me-1"></i> Фото отсутствует</p>
                }
            </div>
        </div>

        <!-- Загрузка нового фото -->
        <div class="mb-4 mt-3">
            <label class="form-label">Новое фото</label>
            <input type="file" name="photoFile" class="form-control" accept="image/*" />
            <small class="form-text text-muted">Оставьте пустым, чтобы сохранить текущее фото. Поддерживаются форматы: JPG, PNG, GIF</small>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-controller="Admin" asp-action="Products" class="btn btn-back text-white">
                <i class="bi bi-arrow-left me-2"></i> Отмена
            </a>
            <button type="submit" class="btn btn-save text-white">
                <i class="bi bi-save me-2"></i> Сохранить изменения
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function() {
            // Функция для получения расчёта цен
            function calculatePrices() {
                var purchaseCost = parseFloat($('#PurchaseCost').val());

                if (purchaseCost && purchaseCost > 0) {
                    $.ajax({
                        url: '/Admin/CalculateSuggestedPrices',
                        type: 'GET',
                        data: { purchaseCost: purchaseCost },
                        success: function(data) {
                            $('#priceHints').slideDown();
                            $('#recommendedPrice').text(data.recommended + ' BYN');
                            $('#breakEvenPrice').text(data.breakEven + ' BYN');
                            $('#profitPerUnit').text(data.profitPerUnit + ' BYN');

                            // Проверка текущей цены
                            var currentPrice = parseFloat($('#SellingPrice').val());
                            var adviceHtml = '';

                            if (currentPrice && currentPrice > 0) {
                                if (currentPrice < data.breakEven) {
                                    $('#currentPriceStatus').html('<span class="text-danger">' + currentPrice.toFixed(2) + ' BYN</span>');
                                    adviceHtml = '<i class="bi bi-exclamation-triangle-fill me-1"></i> ' +
                                        '<strong class="text-danger">ВНИМАНИЕ!</strong> Ваша цена ниже минимальной! ' +
                                        'Вы работаете в убыток. Рекомендуем поднять цену до ' + data.recommended + ' BYN';
                                    $('#currentPriceStatus').addClass('warning');
                                } else if (currentPrice < data.recommended) {
                                    $('#currentPriceStatus').html(currentPrice.toFixed(2) + ' BYN');
                                    adviceHtml = '<i class="bi bi-arrow-up-circle me-1"></i> ' +
                                        'Вы можете поднять цену до рекомендуемой ' + data.recommended + ' BYN, чтобы увеличить прибыль';
                                } else {
                                    $('#currentPriceStatus').html('<span class="text-success">' + currentPrice.toFixed(2) + ' BYN</span>');
                                    adviceHtml = '<i class="bi bi-check-circle-fill me-1"></i> ' +
                                        '✅ Отличная цена! Вы работаете с хорошей прибылью.';
                                }
                            } else {
                                $('#currentPriceStatus').html('не указана');
                                adviceHtml = '<i class="bi bi-info-circle me-1"></i> ' +
                                    'Введите цену продажи. Рекомендуемая цена: ' + data.recommended + ' BYN';
                            }

                            $('#adviceText').html(adviceHtml);
                        },
                        error: function() {
                            $('#priceHints').slideDown();
                            $('#recommendedPrice').text('ошибка расчёта');
                            $('#breakEvenPrice').text('ошибка расчёта');
                            $('#profitPerUnit').text('ошибка расчёта');
                            $('#adviceText').html('<i class="bi bi-exclamation-triangle-fill me-1"></i> Ошибка при расчёте. Проверьте настройки финансов.');
                        }
                    });
                } else {
                    $('#priceHints').slideUp();
                }
            }

            // Событие при вводе себестоимости
            $('#PurchaseCost').on('input', function() {
                calculatePrices();
            });

            // Событие при вводе цены продажи
            $('#SellingPrice').on('input', function() {
                if ($('#PurchaseCost').val() && parseFloat($('#PurchaseCost').val()) > 0) {
                    calculatePrices();
                }
            });

            // Автоматический расчёт при загрузке страницы (если есть себестоимость)
            if ($('#PurchaseCost').val() && parseFloat($('#PurchaseCost').val()) > 0) {
                calculatePrices();
            }
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}