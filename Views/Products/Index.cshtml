@model IEnumerable<StationeryShop.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров";
    bool isAdmin = ViewBag.IsAdmin;
    bool isAuthenticated = ViewBag.IsAuthenticated;
}

<style>
    /* Современные стили в стиле админ-панели */
    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 25px;
        margin-bottom: 30px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }
    
    .filter-section .form-control,
    .filter-section .form-select {
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        padding: 10px 15px;
    }
    
    .filter-section .form-control:focus,
    .filter-section .form-select:focus {
        border-color: #2c5aa0;
        box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
    }
    
    .product-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 20px;
        overflow: hidden;
        background: white;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }
    
    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(44, 90, 160, 0.12);
    }
    
    .product-image {
        height: 220px;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .product-card:hover .product-image {
        transform: scale(1.05);
    }
    
    .card-title {
        cursor: pointer;
        font-weight: 700;
        font-size: 1.1rem;
        transition: color 0.2s ease;
        margin-bottom: 8px;
    }
    
    .card-title:hover {
        color: #2c5aa0;
    }
    
    .stock-badge {
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 600;
    }
    .stock-high { background: #d4edda; color: #155724; }
    .stock-medium { background: #fff3cd; color: #856404; }
    .stock-low { background: #f8d7da; color: #721c24; }
    
    .price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #2c5aa0;
    }
    
    .btn-cart {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 30px;
        padding: 8px 20px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s ease;
        color: white;
        width: 100%;
    }
    
    .btn-cart:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        color: white;
    }
    
    .btn-cart:disabled {
        background: #adb5bd;
        transform: none;
        cursor: not-allowed;
    }
    
    .category-badge {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        padding: 5px 12px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 600;
    }
    
    .view-toggle .btn {
        padding: 8px 20px;
        border-radius: 40px;
        font-weight: 500;
    }
    
    .table-products {
        border-radius: 20px;
        overflow: hidden;
    }
    
    .table-products th {
        background: #f8f9fa;
        font-weight: 600;
        padding: 15px;
        border-bottom: 2px solid #e9ecef;
    }
    
    .table-products td {
        padding: 12px 15px;
        vertical-align: middle;
    }
    
    .table-img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 12px;
    }
    
    .admin-notice {
        background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
        border-radius: 20px;
        padding: 15px 25px;
        margin-bottom: 25px;
        color: white;
    }
    
    .auth-notice {
        background: linear-gradient(135deg, #6c757d, #5a6268);
        border-radius: 20px;
        padding: 15px 25px;
        margin-bottom: 25px;
        color: white;
    }
    
    .section-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a2e;
        position: relative;
        display: inline-block;
        margin-bottom: 1rem;
    }
    
    .section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 4px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 2px;
    }
    
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .product-card {
        animation: fadeInUp 0.5s ease-out;
    }
    
    .modal-content {
        border: none;
        border-radius: 24px;
    }
    
    .modal-header {
        border-bottom: 1px solid #e9ecef;
        padding: 20px 25px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
   
    
    @if (isAdmin)
    {
        <div class="view-toggle">
            <button id="cardViewBtn" class="btn btn-outline-primary active">
                <i class="bi bi-grid-3x3-gap-fill"></i> Карточки
            </button>
            <button id="tableViewBtn" class="btn btn-outline-secondary">
                <i class="bi bi-table"></i> Таблица
            </button>
        </div>
    }
</div>

<!-- Блок для администратора -->
@if (isAdmin)
{
    <div class="admin-notice">
        <i class="bi bi-shield-lock-fill me-2"></i>
        <strong>Режим администратора</strong>
        <br>
        <small>
            Управление товарами, категориями и заказами доступно в 
            <a asp-controller="Admin" asp-action="Index" class="text-white fw-bold text-decoration-underline">
                <i class="bi bi-speedometer2"></i> Админ-панели
            </a>
        </small>
    </div>
}

<!-- Блок для неавторизованных -->
@if (!isAuthenticated)
{
    <div class="auth-notice">
        <i class="bi bi-info-circle-fill me-2"></i>
        <strong>Для оформления заказа необходимо авторизоваться</strong>
        <br>
        <small>
            <a asp-controller="Account" asp-action="Login" class="text-white fw-bold text-decoration-underline">
                <i class="bi bi-box-arrow-in-right"></i> Войти
            </a>
            или 
            <a asp-controller="Account" asp-action="Register" class="text-white fw-bold text-decoration-underline">
                <i class="bi bi-person-plus"></i> Зарегистрироваться
            </a>
        </small>
    </div>
}

<!-- Фильтры -->
<div class="filter-section">
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label class="form-label fw-bold">🔍 Поиск товаров</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Введите название...">
        </div>
        <div class="col-md-4">
            <label class="form-label fw-bold">📁 Категория</label>
            <select id="categoryFilter" class="form-select">
                <option value="">Все категории</option>
                @foreach (var category in Model.Select(p => p.Category).Distinct().Where(c => c != null))
                {
                    <option value="@category.Name">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">📊 Сортировка</label>
            <select id="sortBy" class="form-select">
                <option value="Name">Названию (А-Я)</option>
                <option value="NameDesc">Названию (Я-А)</option>
                <option value="Price">Цене (возр.)</option>
                <option value="PriceDesc">Цене (убыв.)</option>
                <option value="Stock">Остатку (возр.)</option>
                <option value="StockDesc">Остатку (убыв.)</option>
            </select>
        </div>
    </div>
    <div class="row mt-3">
        <div class="col-12">
            <button id="resetFilters" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-repeat"></i> Сбросить фильтры
            </button>
        </div>
    </div>
</div>

<!-- Карточки товаров -->
<div id="cardsContainer" class="row g-4">
    <div class="col-12 text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Загрузка товаров...</p>
    </div>
</div>

<!-- Таблица (только для админа) -->
@if (isAdmin)
{
    <div id="tableViewContainer" style="display: none;">
        <div class="table-responsive">
            <table class="table table-hover table-products">
                <thead>
                    <tr>
                        <th>Фото</th>
                        <th>Название</th>
                        <th>Категория</th>
                        <th>Цена</th>
                        <th>Остаток</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody id="tableBody"></tbody>
            </table>
        </div>
    </div>
}

<!-- Модальное окно -->
<div class="modal fade" id="productModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">📋 Информация о товаре</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="productModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Загрузка...</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentProducts = [];
        let currentView = 'cards';
        let isAdmin = @(isAdmin ? "true" : "false");
        
        function getStockClass(quantity) {
            if (quantity >= 20) return 'stock-high';
            if (quantity >= 5) return 'stock-medium';
            return 'stock-low';
        }
        
        async function loadProducts() {
            const search = $('#searchInput').val();
            const category = $('#categoryFilter').val();
            const sortBy = $('#sortBy').val();
            
            let sortField = 'Name';
            let ascending = true;
            
            switch(sortBy) {
                case 'NameDesc': sortField = 'Name'; ascending = false; break;
                case 'Price': sortField = 'Price'; ascending = true; break;
                case 'PriceDesc': sortField = 'Price'; ascending = false; break;
                case 'Stock': sortField = 'Stock'; ascending = true; break;
                case 'StockDesc': sortField = 'Stock'; ascending = false; break;
                default: sortField = 'Name'; ascending = true;
            }
            
            $('#cardsContainer').html(`
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Загрузка товаров...</p>
                </div>
            `);
            
            try {
                let products = @Html.Raw(Json.Serialize(Model.Select(p => new {
                    p.ProductID,
                    p.Name,
                    p.Description,
                    p.Price,
                    p.StockQuantity,
                    CategoryName = p.Category?.Name,
                    p.PhotoBase64
                })));
                
                if (search) {
                    products = products.filter(p => p.name.toLowerCase().includes(search.toLowerCase()));
                }
                if (category) {
                    products = products.filter(p => p.categoryName === category);
                }
                
                products.sort((a, b) => {
                    let valA, valB;
                    if (sortField === 'Name') {
                        valA = a.name;
                        valB = b.name;
                    } else if (sortField === 'Price') {
                        valA = a.price;
                        valB = b.price;
                    } else {
                        valA = a.stockQuantity;
                        valB = b.stockQuantity;
                    }
                    return ascending ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
                });
                
                currentProducts = products;
                renderCards(products);
                if (isAdmin) renderTable(products);
            } catch (error) {
                console.error('Ошибка загрузки:', error);
                $('#cardsContainer').html('<div class="col-12 text-center py-5 text-danger">Ошибка загрузки товаров</div>');
            }
        }
        
        function renderCards(products) {
            if (!products.length) {
                $('#cardsContainer').html(`
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                        <p class="mt-3 text-muted">Товары не найдены</p>
                    </div>
                `);
                return;
            }
            
            let html = '';
            for (const product of products) {
                const stockClass = getStockClass(product.stockQuantity);
                const isAuthenticated = @(isAuthenticated ? "true" : "false");
                const isAdminUser = @(isAdmin ? "true" : "false");
                const inStock = product.stockQuantity > 0;
                
                html += `
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="card product-card h-100">
                            <div class="card-img-container position-relative">
                                ${product.photoBase64 ? 
                                    `<img src="data:image/png;base64,${product.photoBase64}" class="card-img-top product-image" alt="${escapeHtml(product.name)}" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#productModal" data-product-id="${product.productID}">` :
                                    `<div class="card-img-top product-image d-flex align-items-center justify-content-center bg-light" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#productModal" data-product-id="${product.productID}">
                                        <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                     </div>`
                                }
                                <div class="position-absolute top-0 start-0 m-2">
                                    <span class="category-badge">${escapeHtml(product.categoryName) || 'Без категории'}</span>
                                </div>
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="stock-badge ${stockClass}">${product.stockQuantity} шт</span>
                                </div>
                            </div>
                            <div class="card-body d-flex flex-column p-3">
                                <h5 class="card-title" style="cursor: pointer;" data-bs-toggle="modal" data-bs-target="#productModal" data-product-id="${product.productID}">
                                    ${escapeHtml(product.name)}
                                </h5>
                                <p class="card-text text-muted small flex-grow-1" style="font-size: 0.8rem;">
                                    ${escapeHtml(product.description?.substring(0, 80) || 'Без описания')}${product.description?.length > 80 ? '...' : ''}
                                </p>
                                <div class="mt-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="price">${product.price.toFixed(2)} BYN</span>
                                        <small class="text-muted">Осталось: ${product.stockQuantity}</small>
                                    </div>
                                    ${isAuthenticated && !isAdminUser ? 
                                        (inStock ? 
                                            `<form action="/Cart/AddToCart" method="post" class="d-grid">
                                                <input type="hidden" name="productId" value="${product.productID}" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <button type="submit" class="btn-cart">
                                                    <i class="bi bi-cart-plus"></i> В корзину
                                                </button>
                                            </form>` :
                                            `<button class="btn-cart" disabled>
                                                <i class="bi bi-cart-x"></i> Нет в наличии
                                            </button>`
                                        ) : 
                                        (!isAuthenticated ?
                                            `<button class="btn-cart" disabled title="Для добавления в корзину необходимо авторизоваться">
                                                <i class="bi bi-cart-plus"></i> В корзину
                                            </button>` : ''
                                        )
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }
            $('#cardsContainer').html(html);
            
            $('[data-bs-toggle="modal"]').on('click', function(e) {
                if ($(this).hasClass('btn-cart') || $(this).closest('form').length) return;
                const productId = $(this).data('product-id');
                if (productId) {
                    loadProductModal(productId);
                }
            });
        }
        
        function renderTable(products) {
            if (!products.length) {
                $('#tableBody').html('<tr><td colspan="6" class="text-center text-muted py-5">Товары не найдены</td><tr');
                return;
            }
            
            let html = '';
            for (const product of products) {
                const stockClass = getStockClass(product.stockQuantity);
                html += `
                    <tr>
                        <td>
                            ${product.photoBase64 ? 
                                `<img src="data:image/png;base64,${product.photoBase64}" class="table-img" alt="${escapeHtml(product.name)}">` :
                                `<div class="table-img d-flex align-items-center justify-content-center bg-light rounded">
                                    <i class="bi bi-image text-muted"></i>
                                 </div>`
                            }
                        </td>
                        <td class="fw-bold">${escapeHtml(product.name)}</td>
                        <td><span class="badge bg-primary rounded-pill">${escapeHtml(product.categoryName) || 'Без категории'}</span></td>
                        <td class="text-primary fw-bold">${product.price.toFixed(2)} BYN</td>
                        <td><span class="stock-badge ${stockClass}">${product.stockQuantity} шт</span></td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-info" data-bs-toggle="modal" data-bs-target="#productModal" data-product-id="${product.productID}" title="Детали">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <a href="/Products/Edit/${product.productID}" class="btn btn-outline-primary" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="/Products/Delete/${product.productID}" class="btn btn-outline-danger" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                `;
            }
            $('#tableBody').html(html);
            
            $('[data-bs-toggle="modal"]').on('click', function(e) {
                const productId = $(this).data('product-id');
                if (productId) {
                    loadProductModal(productId);
                }
            });
        }
        
        function loadProductModal(productId) {
            const modalBody = $('#productModalBody');
            modalBody.html(`
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2 text-muted">Загрузка информации...</p>
                </div>
            `);
            
            fetch(`/Products/DetailsModal/${productId}`)
                .then(response => response.text())
                .then(html => {
                    modalBody.html(html);
                })
                .catch(error => {
                    modalBody.html(`
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i> Ошибка при загрузке информации о товаре
                        </div>
                    `);
                });
        }
        
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
        
        function setView(view) {
            currentView = view;
            if (view === 'cards') {
                $('#cardsContainer').show();
                $('#tableViewContainer').hide();
                $('#cardViewBtn').removeClass('btn-primary btn-outline-primary').addClass('btn-primary');
                $('#tableViewBtn').removeClass('btn-primary btn-outline-secondary').addClass('btn-outline-secondary');
            } else {
                $('#cardsContainer').hide();
                $('#tableViewContainer').show();
                $('#tableViewBtn').removeClass('btn-outline-secondary btn-primary').addClass('btn-primary');
                $('#cardViewBtn').removeClass('btn-primary btn-outline-primary').addClass('btn-outline-primary');
            }
        }
        
        $('#searchInput').on('input', debounce(loadProducts, 500));
        $('#categoryFilter').on('change', loadProducts);
        $('#sortBy').on('change', loadProducts);
        $('#resetFilters').on('click', function() {
            $('#searchInput').val('');
            $('#categoryFilter').val('');
            $('#sortBy').val('Name');
            loadProducts();
        });
        
        if (isAdmin) {
            $('#cardViewBtn').on('click', () => setView('cards'));
            $('#tableViewBtn').on('click', () => setView('table'));
        }
        
        function debounce(func, wait) {
            let timeout;
            return function() {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, arguments), wait);
            };
        }
        
        $(document).ready(function() {
            loadProducts();
            if (isAdmin) setView('cards');
        });
    </script>
}