@model StationeryShop.Models.Product

@{
    bool isAuthenticated = Context.Session.GetInt32("CustomerID") != null;
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    .product-modal-image {
        border-radius: 20px;
        width: 100%;
        max-height: 350px;
        object-fit: cover;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .product-modal-placeholder {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        border-radius: 20px;
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-modal-title {
        font-size: 1.8rem;
        font-weight: 700;
        background: linear-gradient(135deg, #1a1a2e, #2c5aa0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 15px;
    }

    .category-badge {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .stock-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .stock-high {
        background: #d4edda;
        color: #155724;
    }

    .stock-medium {
        background: #fff3cd;
        color: #856404;
    }

    .stock-low {
        background: #f8d7da;
        color: #721c24;
    }

    .product-price {
        font-size: 2rem;
        font-weight: 800;
        color: #2c5aa0;
    }

        .product-price small {
            font-size: 0.9rem;
            font-weight: 400;
            color: #6c757d;
        }

    .btn-add-to-cart {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 50px;
        padding: 12px 25px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .btn-add-to-cart:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(40, 167, 69, 0.3);
        }

        .btn-add-to-cart:disabled {
            background: #adb5bd;
            transform: none;
        }

    .info-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }

        .info-card .card-header {
            background: #f8f9fa;
            border-bottom: 1px solid #e9ecef;
            padding: 15px 20px;
            border-radius: 20px 20px 0 0;
        }

            .info-card .card-header h6 {
                font-weight: 700;
                color: #1a1a2e;
                margin: 0;
            }

    .info-table {
        width: 100%;
        margin: 0;
    }

        .info-table td {
            padding: 10px 15px;
            border-bottom: 1px solid #f0f2f5;
        }

        .info-table tr:last-child td {
            border-bottom: none;
        }

        .info-table td:first-child {
            font-weight: 600;
            color: #4a5568;
            width: 40%;
        }

    .alert-auth {
        background: linear-gradient(135deg, #e8f4fd, #d4eaf7);
        border: none;
        border-radius: 16px;
        color: #2c5aa0;
    }

        .alert-auth a {
            color: #2c5aa0;
            font-weight: 600;
        }
</style>

<div class="row g-4">
    <!-- Левая колонка - фото -->
    <div class="col-md-6">
        @if (Model.PhotoBase64 != null)
        {
            <img src="data:image/png;base64,@Model.PhotoBase64"
                 class="product-modal-image"
                 alt="@Model.Name">
        }
        else
        {
            <div class="product-modal-placeholder">
                <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
            </div>
        }
    </div>

    <!-- Правая колонка - информация -->
    <div class="col-md-6">
        <h4 class="product-modal-title">@Model.Name</h4>

        <div class="mb-3 d-flex align-items-center" id="modal-rating-container">
            <div class="rating-stars-modal me-2">
                <i class="bi bi-star-fill text-warning"></i>
                <i class="bi bi-star-fill text-warning"></i>
                <i class="bi bi-star-fill text-warning"></i>
                <i class="bi bi-star-fill text-warning"></i>
                <i class="bi bi-star text-warning"></i>
            </div>
            <span id="modal-rating-text" class="text-muted small">Загрузка...</span>
        </div>

        <div class="mb-3 d-flex flex-wrap gap-2">
            <span class="category-badge text-white">
                <i class="bi bi-tag me-1"></i> @Model.Category?.Name
            </span>
            @if (Model.StockQuantity > 10)
            {
                <span class="stock-badge stock-high">
                    <i class="bi bi-check-circle-fill me-1"></i> В наличии
                </span>
            }
            else if (Model.StockQuantity > 0)
            {
                <span class="stock-badge stock-medium">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Мало осталось
                </span>
            }
            else
            {
                <span class="stock-badge stock-low">
                    <i class="bi bi-x-circle-fill me-1"></i> Нет в наличии
                </span>
            }
        </div>

        <div class="mb-4">
            <div class="product-price">
                @Model.Price.ToString("0.00") BYN
                <small>за штуку</small>
            </div>
            <div class="text-muted mt-1">
                <i class="bi bi-box-seam me-1"></i> Количество на складе: <strong>@Model.StockQuantity</strong> шт.
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mb-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-file-text me-1"></i> Описание</h6>
                <p class="text-muted" style="line-height: 1.6;">@Model.Description</p>
            </div>
        }

        <!-- Кнопки действий -->
        <div class="d-grid gap-2">
            @if (isAuthenticated && !isAdmin)
            {
                if (Model.StockQuantity > 0)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.ProductID" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-add-to-cart w-100 text-white">
                            <i class="bi bi-cart-plus me-2"></i> Добавить в корзину
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-add-to-cart w-100" disabled>
                        <i class="bi bi-cart-x me-2"></i> Товара нет в наличии
                    </button>
                }
            }
            else if (!isAuthenticated)
            {
                <div class="alert alert-auth text-center">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    Для добавления товара в корзину необходимо
                    <a asp-controller="Account" asp-action="Login">войти в систему</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Характеристики товара -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card info-card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i> Подробная информация</h6>
            </div>
            <div class="card-body p-0">
                <table class="info-table">
                    <tr>
                        <td><i class="bi bi-tag me-2"></i> Категория</td>
                        <td>@Model.Category?.Name</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-currency-dollar me-2"></i> Цена</td>
                        <td class="text-primary fw-bold">@Model.Price.ToString("0.00") BYN</td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-box-seam me-2"></i> Наличие</td>
                        <td>
                            @if (Model.StockQuantity > 0)
                            {
                                <span class="text-success">✅ В наличии (@Model.StockQuantity шт.)</span>
                            }
                            else
                            {
                                <span class="text-danger">❌ Нет в наличии</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td><i class="bi bi-upc-scan me-2"></i> Артикул</td>
                        <td>#@Model.ProductID</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function() {
        const productId = @Model.ProductID;

        $.ajax({
            url: '/Products/GetProductRating',
            type: 'GET',
            data: { productId: productId },
            success: function(data) {
                if (data.averageRating > 0) {
                    updateModalStars(data.averageRating);
                    $('#modal-rating-text').text(`${data.averageRating} (${data.totalReviews} отзывов)`);
                } else {
                    $('#modal-rating-text').text('(нет отзывов)');
                }
            },
            error: function() {
                $('#modal-rating-text').text('(нет отзывов)');
            }
        });

        function updateModalStars(rating) {
            const fullStars = Math.floor(rating);
            const hasHalfStar = (rating - fullStars) >= 0.5;
            const $container = $('.rating-stars-modal');
            $container.empty();

            for (let i = 1; i <= 5; i++) {
                if (i <= fullStars) {
                    $container.append('<i class="bi bi-star-fill text-warning"></i>');
                } else if (i === fullStars + 1 && hasHalfStar) {
                    $container.append('<i class="bi bi-star-half text-warning"></i>');
                } else {
                    $container.append('<i class="bi bi-star text-warning"></i>');
                }
            }
        }
    });
</script>