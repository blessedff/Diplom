@model StationeryShop.Models.Product

@{
    bool isAuthenticated = Context.Session.GetInt32("CustomerID") != null;
    bool isAdmin = Context.Session.GetString("IsAdmin") == "true";
}

<style>
    #tab-info,
    #tab-questions {
        min-height: 400px;
    }

    .product-modal-image {
        border-radius: 20px;
        width: 100%;
        max-height: 350px;
        object-fit: cover;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .product-modal-placeholder {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        border-radius: 20px;
        height: 300px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-modal-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 15px;
        word-wrap: break-word;
    }

    .category-badge {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .stock-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .stock-high {
        background: #d4edda;
        color: #155724;
    }

    .stock-medium {
        background: #fff3cd;
        color: #856404;
    }

    .stock-low {
        background: #f8d7da;
        color: #721c24;
    }

    .product-price {
        font-size: 2rem;
        font-weight: 800;
        color: #2c5aa0;
    }

        .product-price small {
            font-size: 0.9rem;
            font-weight: 400;
            color: #6c757d;
        }

    .btn-add-to-cart {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
        border-radius: 50px;
        padding: 12px 25px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .btn-add-to-cart:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(40, 167, 69, 0.3);
        }

        .btn-add-to-cart:disabled {
            background: #adb5bd;
            transform: none;
        }

    .info-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid rgba(0,0,0,0.05);
    }

        .info-card .card-header {
            background: #f8f9fa;
            border-bottom: 1px solid #e9ecef;
            padding: 15px 20px;
            border-radius: 20px 20px 0 0;
        }

            .info-card .card-header h6 {
                font-weight: 700;
                color: #1a1a2e;
                margin: 0;
            }

    .info-table {
        width: 100%;
        margin: 0;
    }

        .info-table td {
            padding: 10px 15px;
            border-bottom: 1px solid #f0f2f5;
            vertical-align: top;
        }

        .info-table tr:last-child td {
            border-bottom: none;
        }

        .info-table td:first-child {
            font-weight: 600;
            color: #4a5568;
            width: 35%;
        }

    .alert-auth {
        background: linear-gradient(135deg, #e8f4fd, #d4eaf7);
        border: none;
        border-radius: 16px;
        color: #2c5aa0;
    }

        .alert-auth a {
            color: #2c5aa0;
            font-weight: 600;
        }

    .modal-tabs {
        display: flex;
        gap: 0;
        border-bottom: 1px solid #e9ecef;
        margin-bottom: 20px;
    }

    .tab-btn {
        padding: 10px 20px;
        background: none;
        border: none;
        font-size: 1rem;
        font-weight: 600;
        color: #6c757d;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

        .tab-btn:hover {
            color: #2c5aa0;
        }

        .tab-btn.active {
            color: #2c5aa0;
        }

            .tab-btn.active::after {
                content: '';
                position: absolute;
                bottom: -1px;
                left: 0;
                right: 0;
                height: 2px;
                background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
            }

    .tab-content {
        display: none;
        animation: fadeIn 0.3s ease;
    }

        .tab-content.active {
            display: block;
        }

    @@keyframes fadeIn {
        from

    {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .questions-list {
        max-height: 400px;
        overflow-y: auto;
        margin-bottom: 20px;
    }

    .question-item {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 15px;
        margin-bottom: 15px;
    }

    .question-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
    }

    .question-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .question-avatar i {
            font-size: 1.2rem;
            color: white;
        }

    .question-user-info {
        flex: 1;
    }

    .question-user-name {
        font-weight: 700;
        font-size: 0.9rem;
        color: #1a1a2e;
    }

    .question-date {
        font-size: 0.7rem;
        color: #6c757d;
    }

    .question-text {
        color: #4a5568;
        font-size: 0.9rem;
        line-height: 1.5;
        margin-bottom: 12px;
    }

        .question-text i {
            color: #2c5aa0;
            margin-right: 6px;
        }

    .answer-block {
        background: white;
        border-radius: 12px;
        padding: 12px;
        margin-top: 10px;
        border-left: 3px solid #28a745;
    }

    .answer-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #28a745;
    }

    .answer-text {
        font-size: 0.85rem;
        color: #4a5568;
    }

    .waiting-badge {
        display: inline-block;
        background: #fff3cd;
        color: #856404;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .ask-question-form {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 20px;
        margin-top: 20px;
    }

        .ask-question-form h6 {
            font-weight: 700;
            margin-bottom: 15px;
        }

        .ask-question-form textarea {
            width: 100%;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px;
            font-size: 0.85rem;
            resize: vertical;
        }

            .ask-question-form textarea:focus {
                border-color: #2c5aa0;
                outline: none;
            }

    .btn-ask {
        background: linear-gradient(135deg, #2c5aa0, #3a7bd5);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 8px 24px;
        font-weight: 600;
        font-size: 0.85rem;
        margin-top: 10px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-ask:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
        }

    .auth-required-box {
        background: linear-gradient(135deg, #6c757d, #5a6268);
        border-radius: 20px;
        padding: 30px 25px;
        margin-top: 20px;
        text-align: center;
        color: white;
    }

    .auth-icon {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.15);
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
    }

        .auth-icon i {
            font-size: 1.8rem;
            color: white;
        }

    .auth-required-box h5 {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .auth-text {
        font-size: 0.85rem;
        margin-bottom: 12px;
        opacity: 0.9;
    }

    .auth-small {
        font-size: 0.7rem;
        opacity: 0.75;
    }

    .auth-link {
        color: #ffc107;
        text-decoration: none;
        font-weight: 600;
    }

        .auth-link:hover {
            color: #fff;
            text-decoration: underline;
        }

    .toast-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        padding: 12px 20px;
        border-radius: 12px;
        font-size: 0.9rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.15);
        animation: slideInRight 0.3s ease;
    }

        .toast-notification.success {
            background: #d4edda;
            color: #155724;
            border-left: 4px solid #28a745;
        }

        .toast-notification.error {
            background: #f8d7da;
            color: #721c24;
            border-left: 4px solid #dc3545;
        }

    @@keyframes slideInRight {
        from

    {
        transform: translateX(100px);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }
</style>

<div class="modal-tabs">
    <button class="tab-btn active" data-tab="info">📦 Информация о товаре</button>
    <button class="tab-btn" data-tab="questions">💬 Вопросы <span id="questionsCount">(0)</span></button>
</div>

<!-- Вкладка 1: Информация о товаре -->
<div id="tab-info" class="tab-content active">
    <div class="row g-4">
        <div class="col-md-6">
            @if (Model.PhotoBase64 != null)
            {
                <img src="data:image/png;base64,@Model.PhotoBase64" class="product-modal-image" alt="@Model.Name">
            }
            else
            {
                <div class="product-modal-placeholder">
                    <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                </div>
            }
        </div>

        <div class="col-md-6">
            <h4 class="product-modal-title">@Model.Name</h4>

            <div class="mb-3 d-flex align-items-center" id="modal-rating-container">
                <div class="rating-stars-modal me-2">
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star text-warning"></i>
                </div>
                <span id="modal-rating-text" class="text-muted small">Загрузка...</span>
            </div>

            <div class="mb-3 d-flex flex-wrap gap-2">
                <span class="category-badge text-white">
                    <i class="bi bi-tag me-1"></i> @Model.Category?.Name
                </span>
                @if (Model.StockQuantity > 10)
                {
                    <span class="stock-badge stock-high"><i class="bi bi-check-circle-fill me-1"></i> В наличии</span>
                }
                else if (Model.StockQuantity > 0)
                {
                    <span class="stock-badge stock-medium"><i class="bi bi-exclamation-triangle-fill me-1"></i> Мало осталось</span>
                }
                else
                {
                    <span class="stock-badge stock-low"><i class="bi bi-x-circle-fill me-1"></i> Нет в наличии</span>
                }
            </div>

            <div class="mb-4">
                <div class="product-price">
                    @Model.Price.ToString("0.00") BYN
                    <small>за штуку</small>
                </div>
                <div class="text-muted mt-1">
                    <i class="bi bi-box-seam me-1"></i> Количество на складе: <strong>@Model.StockQuantity</strong> шт.
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mb-4">
                    <h6 class="fw-bold mb-2"><i class="bi bi-file-text me-1"></i> Описание</h6>
                    <p class="text-muted" style="line-height: 1.6;">@Model.Description</p>
                </div>
            }

            <div class="d-grid gap-2">
                @if (isAuthenticated && !isAdmin)
                {
                    if (Model.StockQuantity > 0)
                    {
                        <button type="button" id="addToCartBtn" class="btn btn-add-to-cart w-100 text-white" data-product-id="@Model.ProductID">
                            <i class="bi bi-cart-plus me-2"></i> Добавить в корзину
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-add-to-cart w-100" disabled>
                            <i class="bi bi-cart-x me-2"></i> Товара нет в наличии
                        </button>
                    }
                }
                else if (!isAuthenticated)
                {
                    <div class="alert alert-auth text-center">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Для добавления товара в корзину необходимо
                        <a asp-controller="Account" asp-action="Login">войти в систему</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card info-card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i> Подробная информация</h6>
                </div>
                <div class="card-body p-0">
                    <table class="info-table">
                        <tbody>
                            <tr>
                                <td><i class="bi bi-tag me-2"></i> Категория</td>
                                <td>@Model.Category?.Name</td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-currency-dollar me-2"></i> Цена</td>
                                <td class="text-primary fw-bold">@Model.Price.ToString("0.00") BYN</td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-box-seam me-2"></i> Наличие</td>
                                <td>
                                    @if (Model.StockQuantity > 0)
                                    {
                                        <span class="text-success">✅ В наличии (@Model.StockQuantity шт.)</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">❌ Нет в наличии</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td><i class="bi bi-upc-scan me-2"></i> Артикул</td>
                                <td>#@Model.ProductID</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Вкладка 2: Вопросы о товаре -->
<div id="tab-questions" class="tab-content">
    <div id="questionsContainer">
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Загрузка вопросов...</p>
        </div>
    </div>

    @if (isAuthenticated && !isAdmin)
    {
        <div class="ask-question-form">
            <h6><i class="bi bi-question-circle"></i> Задать вопрос о товаре</h6>
            <textarea id="questionText" class="form-control" rows="3" placeholder="Напишите ваш вопрос..." maxlength="1000"></textarea>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">Максимум 1000 символов</small>
                <button id="submitQuestionBtn" class="btn-ask" data-product-id="@Model.ProductID">
                    <i class="bi bi-send"></i> Отправить вопрос
                </button>
            </div>
        </div>
    }
    else if (!isAuthenticated)
    {
        <div class="auth-required-box">
            <div class="auth-icon">
                <i class="bi bi-chat-dots"></i>
            </div>
            <h5>Хотите задать вопрос?</h5>
            <p class="auth-text">
                Чтобы задать вопрос о товаре, необходимо
                <a asp-controller="Account" asp-action="Login" class="auth-link">войти в аккаунт</a>.
            </p>
            <small class="auth-small">
                <i class="bi bi-question-circle me-1"></i>
                Нет аккаунта? <a asp-controller="Account" asp-action="Register" class="auth-link">Зарегистрируйтесь</a>
            </small>
        </div>
    }
</div>

<script>
    (function() {
        let currentProductId = @Model.ProductID;
        let isSubmitting = false;

        // Рейтинг
        $.ajax({
            url: '/Products/GetProductRating',
            type: 'GET',
            data: { productId: currentProductId },
            success: function(data) {
                if (data.averageRating > 0) {
                    updateModalStars(data.averageRating);
                    $('#modal-rating-text').text(data.averageRating + ' (' + data.totalReviews + ' отзывов)');
                } else {
                    $('#modal-rating-text').text('(нет отзывов)');
                }
            },
            error: function() {
                $('#modal-rating-text').text('(нет отзывов)');
            }
        });

        function updateModalStars(rating) {
            var fullStars = Math.floor(rating);
            var hasHalfStar = (rating - fullStars) >= 0.5;
            var $container = $('.rating-stars-modal');
            $container.empty();
            for (var i = 1; i <= 5; i++) {
                if (i <= fullStars) {
                    $container.append('<i class="bi bi-star-fill text-warning"></i>');
                } else if (i === fullStars + 1 && hasHalfStar) {
                    $container.append('<i class="bi bi-star-half text-warning"></i>');
                } else {
                    $container.append('<i class="bi bi-star text-warning"></i>');
                }
            }
        }

        // Переключение вкладок
        $('.tab-btn').off('click').on('click', function() {
            var tabId = $(this).data('tab');
            $('.tab-btn').removeClass('active');
            $('.tab-content').removeClass('active');
            $(this).addClass('active');
            $('#tab-' + tabId).addClass('active');
            if (tabId === 'questions') {
                loadQuestions(currentProductId);
            }
        });

        // Загрузка вопросов
        function loadQuestions(productId) {
            var $container = $('#questionsContainer');
            $container.html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">Загрузка вопросов...</p></div>');
            $.ajax({
                url: '/Products/GetProductQuestions',
                type: 'GET',
                data: { productId: productId },
                success: function(questions) {
                    $('#questionsCount').text('(' + questions.length + ')');
                    if (questions.length === 0) {
                        $container.html('<div class="empty-questions"><i class="bi bi-chat-dots fs-1"></i><p class="mt-2">Пока нет вопросов. Будьте первым, кто спросит!</p></div>');
                        return;
                    }
                    var html = '<div class="questions-list">';
                    for (var i = 0; i < questions.length; i++) {
                        var q = questions[i];
                        var date = new Date(q.questionDate).toLocaleDateString('ru-RU');
                        html += '<div class="question-item">';
                        html += '<div class="question-header"><div class="question-avatar"><i class="bi bi-person-fill"></i></div>';
                        html += '<div class="question-user-info"><div class="question-user-name">' + escapeHtml(q.customerName) + '</div>';
                        html += '<div class="question-date">' + date + '</div></div></div>';
                        html += '<div class="question-text"><i class="bi bi-question-circle"></i> ' + escapeHtml(q.question) + '</div>';
                        if (q.answer) {
                            var answerDate = new Date(q.answerDate).toLocaleDateString('ru-RU');
                            html += '<div class="answer-block"><div class="answer-header"><i class="bi bi-reply-fill"></i> Ответ администратора</div>';
                            html += '<div class="answer-text">' + escapeHtml(q.answer) + '</div>';
                            html += '<div class="question-date mt-1">' + answerDate + '</div></div>';
                        } else {
                            html += '<div class="waiting-badge">Ожидает ответа</div>';
                        }
                        html += '</div>';
                    }
                    html += '</div>';
                    $container.html(html);
                },
                error: function() {
                    $container.html('<div class="alert alert-danger">Ошибка при загрузке вопросов</div>');
                }
            });
        }

        // Отправка вопроса
        $(document).off('click', '#submitQuestionBtn');
        $(document).on('click', '#submitQuestionBtn', async function() {
            if (isSubmitting) return;
            var $btn = $(this);
            var productId = parseInt($btn.data('product-id'));
            var question = $('#questionText').val().trim();
            if (!question) {
                showNotification('Введите текст вопроса', 'error');
                return;
            }
            if (question.length > 1000) {
                showNotification('Вопрос не должен превышать 1000 символов', 'error');
                return;
            }
            isSubmitting = true;
            var originalText = $btn.html();
            $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Отправка...');
            try {
                var response = await fetch('/Products/AddQuestion', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, question: question })
                });
                var result = await response.json();
                if (result.success) {
                    $('#questionText').val('');
                    showNotification('Ваш вопрос отправлен! Он будет опубликован после проверки администратором.', 'success');
                    loadQuestions(productId);
                } else {
                    showNotification(result.message || 'Ошибка при отправке вопроса', 'error');
                }
            } catch (error) {
                showNotification('Ошибка при отправке вопроса. Попробуйте позже.', 'error');
            } finally {
                isSubmitting = false;
                $btn.prop('disabled', false).html(originalText);
            }
        });

        // Добавление в корзину
        $(document).off('click', '#addToCartBtn');
        $(document).on('click', '#addToCartBtn', async function() {
            var $btn = $(this);
            var productId = $btn.data('product-id');
            var originalText = $btn.html();
            $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-2"></i> Добавление...');
            try {
                var response = await fetch('/Cart/AddToCartAjax', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'productId=' + productId + '&quantity=1'
                });
                var result = await response.json();
                if (result.success) {
                    showNotification('Товар добавлен в корзину!', 'success');
                    updateCartCounter();
                    $btn.html('<i class="bi bi-check-lg me-2"></i> В корзине');
                    setTimeout(function() {
                        $btn.html(originalText).prop('disabled', false);
                    }, 2000);
                } else {
                    showNotification(result.message || 'Ошибка при добавлении', 'error');
                    $btn.html(originalText).prop('disabled', false);
                }
            } catch (error) {
                showNotification('Ошибка при добавлении в корзину', 'error');
                $btn.html(originalText).prop('disabled', false);
            }
        });

        function updateCartCounter() {
            fetch('/Cart/GetCartSummary')
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    var cartCounter = $('#cartItemsCount');
                    if (cartCounter.length) {
                        var totalItems = data.totalItems || 0;
                        cartCounter.text(totalItems);
                        if (totalItems > 0) {
                            cartCounter.show();
                        } else {
                            cartCounter.hide();
                        }
                    }
                })
                .catch(function(error) { console.error('Error updating cart counter:', error); });
        }

        function showNotification(message, type) {
            var notifClass = type === 'success' ? 'success' : 'error';
            var iconClass = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-triangle-fill';
            var $notif = $('<div class="toast-notification ' + notifClass + '"><i class="bi ' + iconClass + '"></i><span>' + message + '</span></div>');
            $('body').append($notif);
            setTimeout(function() {
                $notif.fadeOut(300, function() { $(this).remove(); });
            }, 3000);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        loadQuestions(currentProductId);
    })();
</script>