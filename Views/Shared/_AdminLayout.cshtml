<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Админ-панель - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        /* Простые стили без сложностей */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            background-color: #1a1a2e;
            color: white;
            overflow-y: auto;
            z-index: 1000;
        }

            .admin-sidebar .logo {
                padding: 20px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                text-align: center;
            }

            .admin-sidebar .nav-link {
                color: rgba(255,255,255,0.8);
                padding: 12px 20px;
                display: block;
                text-decoration: none;
            }

                .admin-sidebar .nav-link:hover {
                    background-color: rgba(255,255,255,0.1);
                }

                .admin-sidebar .nav-link.active {
                    background-color: #3a7bd5;
                }

                .admin-sidebar .nav-link i {
                    margin-right: 10px;
                    width: 20px;
                }

        .admin-content {
            margin-left: 260px;
            padding: 20px;
            min-height: 100vh;
            background-color: #f0f2f5;
        }

        .admin-header {
            background: white;
            border-radius: 10px;
            padding: 15px 20px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .test-banner {
            background: #28a745;
            color: white;
            padding: 10px;
            margin-bottom: 15px;
            border-radius: 8px;
            text-align: center;
        }
    </style>
</head>
<body>
    <!-- БОКОВОЕ МЕНЮ -->
    <div class="admin-sidebar">
        <div class="logo">
            <h5><i class="bi bi-shop-window"></i> Admin Panel</h5>
            <small>Канцелярский магазин</small>
        </div>

        <div class="sidebar-divider" style="padding: 10px 20px; font-size: 12px; color: rgba(255,255,255,0.5);">НАВИГАЦИЯ</div>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Admin" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Главная
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Products" ? "active" : "")"
           asp-controller="Admin" asp-action="Products">
            <i class="bi bi-box-seam"></i> Товары
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Categories" ? "active" : "")"
           asp-controller="Admin" asp-action="Categories">
            <i class="bi bi-tags"></i> Категории
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Orders" ? "active" : "")"
           asp-controller="Admin" asp-action="Orders">
            <i class="bi bi-bag-check"></i> Заказы
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Customers" ? "active" : "")"
           asp-controller="Admin" asp-action="Customers">
            <i class="bi bi-people"></i> Клиенты
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Analytics" ? "active" : "")"
           asp-controller="Admin" asp-action="Analytics">
            <i class="bi bi-graph-up"></i> Аналитика
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LoginAttempts" ? "active" : "")"
           asp-controller="Admin" asp-action="LoginAttempts">
            <i class="bi bi-shield-lock"></i> Логи входов
        </a>

        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")"
           asp-controller="Admin" asp-action="Settings">
            <i class="bi bi-gear"></i> Настройки
        </a>

        <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 20px;">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light w-100">
                <i class="bi bi-box-arrow-left"></i> На сайт
            </a>
        </div>
    </div>

    <!-- ОСНОВНОЙ КОНТЕНТ -->
    <div class="admin-content">
        <div class="admin-header">
            <h2>@ViewData["Title"]</h2>
            <div>
                <span><i class="bi bi-person-circle"></i> @Context.Session.GetString("CustomerName")</span>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-danger btn-sm ms-3">Выйти</a>
            </div>
        </div>



        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>