<!DOCTYPE html>
<html lang="ru" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Канцелярский Магазин</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #2c5aa0;
            --primary-dark: #1e3a6f;
            --primary-light: #3a7bd5;
            --secondary: #6c757d;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
            --info: #17a2b8;
            --dark: #1a1a2e;
            --light: #f8f9fa;
        }

        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            background-color: #f0f2f5;
            color: #2d3748;
            line-height: 1.6;
        }

        /* Навигация - современный стиль */
        .navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #2c5aa0 100%) !important;
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.1);
            padding: 0.8rem 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.4rem;
            letter-spacing: -0.5px;
            color: white !important;
        }

        .brand-icon {
            background: rgba(255,255,255,0.15);
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .navbar-nav .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 12px;
            transition: all 0.3s ease;
            margin: 0 0.1rem;
        }

            .navbar-nav .nav-link:hover {
                color: white !important;
                background-color: rgba(255,255,255,0.12);
                transform: translateY(-2px);
            }

            .navbar-nav .nav-link.active {
                background: linear-gradient(135deg, #3a7bd5, #00d2ff);
                color: white !important;
                box-shadow: 0 4px 15px rgba(58, 123, 213, 0.3);
            }

        .dropdown-menu {
            background: white;
            border-radius: 16px;
            margin-top: 10px;
            border: none;
            box-shadow: 0 10px 35px rgba(0,0,0,0.1);
            min-width: 200px; 
            padding: 8px 0; 
        }

        .dropdown-item {
            padding: 10px 20px;
            font-size: 0.9rem;
            transition: all 0.2s ease;
            border-radius: 10px;
            margin: 2px 8px; 
            width: auto;
        }

            .dropdown-item:hover {
                background: #f0f2f5;
                transform: translateX(5px);
            }

            .dropdown-item.text-danger:hover {
                background: #fee2e2;
            }

        /* Кнопка регистрации */
        .btn-register {
            background: rgba(255,255,255,0.15);
            border-radius: 30px !important;
        }

            .btn-register:hover {
                /* background: rgba(255,255,255,0.25) !important;*/
                transform: translateY(-2px);
            }

        /* Аватар пользователя */
        .user-avatar-small {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Карточки */
        .card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            background: white;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            }

        /* Кнопки */
        .btn {
            border-radius: 12px;
            font-weight: 500;
            padding: 0.6rem 1.5rem;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(44, 90, 160, 0.3);
            }

        .btn-success {
            background: linear-gradient(135deg, var(--success) 0%, #20c997 100%);
        }

            .btn-success:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
            }

        /* Формы */
        .form-control, .form-select {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 0.75rem 1rem;
            transition: all 0.3s ease;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
            }

        /* Футер */
        .footer {
            background: linear-gradient(135deg, var(--dark) 0%, #16213e 100%);
            color: white;
            margin-top: 4rem;
            padding: 2.5rem 0;
        }

        /* Анимации */
        .fade-in {
            animation: fadeIn 0.5s ease-in-out;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Алерты */
        .alert {
            border: none;
            border-radius: 16px;
            border-left: 4px solid;
        }

        .alert-success {
            border-left-color: var(--success);
        }

        .alert-danger {
            border-left-color: var(--danger);
        }

        .alert-info {
            border-left-color: var(--primary);
        }

        .alert-warning {
            border-left-color: var(--warning);
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Навигация -->
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <div class="brand-icon me-2">
                    <i class="bi bi-shop-window fs-4"></i>
                </div>
                <div>
                    <span class="fw-bold">Канцелярский</span>
                    <span class="fw-light">Магазин</span>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Главная
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Products" ? "active" : "")"
                           asp-controller="Products" asp-action="Index">
                            <i class="bi bi-box-seam me-1"></i>Товары
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
                           asp-controller="Categories" asp-action="Index">
                            <i class="bi bi-tags me-1"></i>Категории
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reviews" ? "active" : "")"
                           asp-controller="Reviews" asp-action="Index">
                            <i class="bi bi-chat-dots me-1"></i>Отзывы
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav">
                    @if (Context.Session.GetInt32("CustomerID") != null)
                    {
                        @if (Context.Session.GetString("IsAdmin") != "true")
                        {
                            <li class="nav-item">
                                <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart3 me-1"></i>Корзина
                                    <span id="cartItemsCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">0</span>
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
                                <div class="user-avatar-small me-2">
                                    <i class="bi bi-person-circle fs-5"></i>
                                </div>
                                <span>@Context.Session.GetString("CustomerName")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-3">
                                @if (Context.Session.GetString("IsAdmin") == "true")
                                {
                                    <li><a class="dropdown-item py-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2 text-primary"></i>Панель администратора</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Личный кабинет</a></li>
                                
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Выйти</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Вход
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn-register" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Регистрация
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Основной контент -->
    <main class="fade-in">
        <div class="container mt-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <!-- Футер -->
    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-3"><i class="bi bi-shop-window me-2"></i>Канцелярский Магазин</h5>
                    <p class="mb-0">Магазин качественных канцтоваров для офиса, школы и творчества</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-1">&copy; 2025 Канцелярский Магазин. Все права защищены.</p>
                   
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        function updateCartCounter() {
            fetch('/Cart/GetCartSummary')
                .then(response => response.json())
                .then(data => {
                    const cartCounter = document.getElementById('cartItemsCount');
                    if (cartCounter) {
                        cartCounter.textContent = data.totalItems;
                        cartCounter.style.display = data.totalItems > 0 ? 'block' : 'none';
                    }
                })
                .catch(error => console.error('Error updating cart counter:', error));
        }

        document.addEventListener('DOMContentLoaded', function () {
            updateCartCounter();
            setTimeout(() => {
                document.querySelectorAll('.alert').forEach(alert => {
                    const bsAlert = new bootstrap.Alert(alert);
                    bsAlert.close();
                });
            }, 5000);
        });
        setInterval(updateCartCounter, 30000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>